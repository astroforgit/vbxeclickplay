     1 				; ============================================================================
     2 				; FujiNet N: Device SIO Layer
     3 				; ============================================================================
     4
     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 2F15 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
    13 = 0080			SIO_WRITE      = $80
    14 = 0000			SIO_NONE       = $00
    15 = 0004			FN_OPEN_READ   = 4
    16 = 0000			FN_TRANS_NONE  = 0
    17 = 001E			FN_TIMEOUT     = 30
    18 = 0100			URL_BUF_SIZE   = 256
    19 = 0100			RX_BUF_SIZE    = 256
    20
    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 2F16			.proc fn_open
    26 2F16 A9 71		        lda #FN_DEVID
    27 2F18 8D 00 03		        sta DDEVIC
    28 2F1B AD 15 2F		        lda fn_cur_unit
    29 2F1E 8D 01 03		        sta DUNIT
    30 2F21 A9 4F		        lda #FN_CMD_OPEN
    31 2F23 8D 02 03		        sta DCOMND
    32 2F26 A9 80		        lda #SIO_WRITE
    33 2F28 8D 03 03		        sta DSTATS
    34 2F2B A9 33		        lda #<url_buffer
    35 2F2D 8D 04 03		        sta DBUFLO
    36 2F30 A9 88		        lda #>url_buffer
    37 2F32 8D 05 03		        sta DBUFHI
    38 2F35 A9 1E		        lda #FN_TIMEOUT
    39 2F37 8D 06 03		        sta DTIMLO
    40 2F3A A9 00		        lda #<URL_BUF_SIZE
    41 2F3C 8D 08 03		        sta DBYTLO
    42 2F3F A9 01		        lda #>URL_BUF_SIZE
    43 2F41 8D 09 03		        sta DBYTHI
    44 2F44 A9 04		        lda #FN_OPEN_READ
    45 2F46 8D 0A 03		        sta DAUX1
    46 2F49 A9 00		        lda #FN_TRANS_NONE
    47 2F4B 8D 0B 03		        sta DAUX2
    48
    49 2F4E 20 59 E4		        jsr SIOV
    50 2F51 AD 03 03		        lda DSTATS
    51 2F54 30 02		        bmi ?err
    52 2F56 18			        clc
    53 2F57 60			        rts
    54 2F58 38			?err    sec
    55 2F59 60			        rts
    56 				.endp
