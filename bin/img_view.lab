    30 2F3F A9 4F		        lda #FN_CMD_OPEN
    31 2F41 8D 02 03		        sta DCOMND
    32 2F44 A9 80		        lda #SIO_WRITE
    33 2F46 8D 03 03		        sta DSTATS
    34 2F49 A9 35		        lda #<url_buffer
    35 2F4B 8D 04 03		        sta DBUFLO
    36 2F4E A9 88		        lda #>url_buffer
    37 2F50 8D 05 03		        sta DBUFHI
    38 2F53 A9 1E		        lda #FN_TIMEOUT
    39 2F55 8D 06 03		        sta DTIMLO
    40 2F58 A9 00		        lda #<URL_BUF_SIZE
    41 2F5A 8D 08 03		        sta DBYTLO
    42 2F5D A9 01		        lda #>URL_BUF_SIZE
