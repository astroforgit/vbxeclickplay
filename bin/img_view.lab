   229 				; ----------------------------------------------------------------------------
   230 				; Macros
   231 				; ----------------------------------------------------------------------------
   232
   233 				; MEMAC B macros with shadow variable for interrupt-safe restore.
   234 				; IMPORTANT: Code using these macros MUST be below $4000!
   235 				; When MEMAC B is active, $4000-$7FFF reads VRAM, not RAM.
   236 				; Interrupt handlers use stubs at page 6 to disable/restore MEMAC B.
   237 				memb_on .macro
   238 				        lda #$80+:1
   239 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   240 				        ldy #VBXE_MEMAC_B
   241 				        sta (zp_vbxe_base),y
   242 				        .endm
   243
   244 				memb_off .macro
   245 				        lda #0
   246 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   247 				        ldy #VBXE_MEMAC_B
   248 				        sta (zp_vbxe_base),y
   249 				        .endm
   250
   251 				; Show message on status bar: :1=color, :2=message address
   252 				; Expands to subroutine call (9 bytes) instead of inline (31 bytes)
   253 				status_msg .macro
   254 				        ldy #:1
   255 				        lda #<:2
   256 				        ldx #>:2
   257 				        jsr status_msg_sub
   258 				        .endm
   259
   260 				; Wait N frames (RTCLOK-based delay): :1=frame count
   261 				; Expands to subroutine call (5 bytes) instead of inline (13 bytes)
   262 				wait_frames .macro
   263 				        ldx #:1
   264 				        jsr wait_frames_sub
   265 				        .endm
   266
   267 				blit_start .macro
   268 				        ldy #VBXE_BL_ADR0
   269 				        lda #<:1
   270 				        sta (zp_vbxe_base),y
   271 				        iny
   272 				        lda #>:1
   273 				        sta (zp_vbxe_base),y
   274 				        iny
   275 				        lda #0
   276 				        sta (zp_vbxe_base),y
   277 				        iny
   278 				        lda #1
   279 				        sta (zp_vbxe_base),y
   280 				        .endm
   281
   282 				blit_wait .macro
   283 				        ldy #VBXE_BLITTER
   284 				?bw     lda (zp_vbxe_base),y
   285 				        bne ?bw
   286 				        .endm
