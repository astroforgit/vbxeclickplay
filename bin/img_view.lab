   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 338B			.proc fn_close
   170 338B A9 71		        lda #FN_DEVID
   171 338D 8D 00 03		        sta DDEVIC
   172 3390 AD 8A 32		        lda fn_cur_unit
   173 3393 8D 01 03		        sta DUNIT
   174 3396 A9 43		        lda #FN_CMD_CLOSE
   175 3398 8D 02 03		        sta DCOMND
   176 339B A9 00		        lda #SIO_NONE
   177 339D 8D 03 03		        sta DSTATS
   178 33A0 A9 00		        lda #0
   179 33A2 8D 04 03		        sta DBUFLO
   180 33A5 8D 05 03		        sta DBUFHI
   181 33A8 8D 08 03		        sta DBYTLO
   182 33AB 8D 09 03		        sta DBYTHI
   183 33AE 8D 0A 03		        sta DAUX1
   184 33B1 8D 0B 03		        sta DAUX2
   185 33B4 A9 1E		        lda #FN_TIMEOUT
   186 33B6 8D 06 03		        sta DTIMLO
   187
   188 33B9 4C 59 E4		        jmp SIOV
   189 				.endp
