     1 				; ============================================================================
     2 				; FujiNet N: Device SIO Layer
     3 				; ============================================================================
     4
     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 3CBC 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
    13 = 0080			SIO_WRITE      = $80
    14 = 0000			SIO_NONE       = $00
    15 = 0004			FN_OPEN_READ   = 4
    16 = 0000			FN_TRANS_NONE  = 0
    17 = 001E			FN_TIMEOUT     = 30
    18 = 0100			URL_BUF_SIZE   = 256
    19 = 0100			RX_BUF_SIZE    = 256
    20
    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 3CBD			.proc fn_open
    26 3CBD A9 71		        lda #FN_DEVID
    27 3CBF 8D 00 03		        sta DDEVIC
    28 3CC2 AD BC 3C		        lda fn_cur_unit
    29 3CC5 8D 01 03		        sta DUNIT
    30 3CC8 A9 4F		        lda #FN_CMD_OPEN
    31 3CCA 8D 02 03		        sta DCOMND
    32 3CCD A9 80		        lda #SIO_WRITE
    33 3CCF 8D 03 03		        sta DSTATS
    34 3CD2 A9 F5		        lda #<url_buffer
    35 3CD4 8D 04 03		        sta DBUFLO
    36 3CD7 A9 88		        lda #>url_buffer
    37 3CD9 8D 05 03		        sta DBUFHI
    38 3CDC A9 1E		        lda #FN_TIMEOUT
    39 3CDE 8D 06 03		        sta DTIMLO
    40 3CE1 A9 00		        lda #<URL_BUF_SIZE
    41 3CE3 8D 08 03		        sta DBYTLO
    42 3CE6 A9 01		        lda #>URL_BUF_SIZE
    43 3CE8 8D 09 03		        sta DBYTHI
    44 3CEB A9 04		        lda #FN_OPEN_READ
    45 3CED 8D 0A 03		        sta DAUX1
    46 3CF0 A9 00		        lda #FN_TRANS_NONE
    47 3CF2 8D 0B 03		        sta DAUX2
    48
    49 3CF5 20 59 E4		        jsr SIOV
    50 3CF8 AD 03 03		        lda DSTATS
    51 3CFB 30 02		        bmi ?err
    52 3CFD 18			        clc
    53 3CFE 60			        rts
    54 3CFF 38			?err    sec
    55 3D00 60			        rts
    56 				.endp
    57
    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 3D01			.proc fn_status
    65 3D01 A9 71		        lda #FN_DEVID
    66 3D03 8D 00 03		        sta DDEVIC
    67 3D06 AD BC 3C		        lda fn_cur_unit
    68 3D09 8D 01 03		        sta DUNIT
    69 3D0C A9 53		        lda #FN_CMD_STATUS
    70 3D0E 8D 02 03		        sta DCOMND
    71 3D11 A9 40		        lda #SIO_READ
    72 3D13 8D 03 03		        sta DSTATS
    73 3D16 A9 EA		        lda #<DVSTAT
    74 3D18 8D 04 03		        sta DBUFLO
    75 3D1B A9 02		        lda #>DVSTAT
    76 3D1D 8D 05 03		        sta DBUFHI
    77 3D20 A9 1E		        lda #FN_TIMEOUT
    78 3D22 8D 06 03		        sta DTIMLO
    79 3D25 A9 04		        lda #4
    80 3D27 8D 08 03		        sta DBYTLO
    81 3D2A A9 00		        lda #0
    82 3D2C 8D 09 03		        sta DBYTHI
    83 3D2F 8D 0A 03		        sta DAUX1
    84 3D32 8D 0B 03		        sta DAUX2
    85
    86 3D35 20 59 E4		        jsr SIOV
    87 3D38 AD 03 03		        lda DSTATS
    88 3D3B 30 16		        bmi ?err
    89
    90 3D3D AD EA 02		        lda DVSTAT
    91 3D40 85 A1		        sta zp_fn_bytes_lo
    92 3D42 AD EB 02		        lda DVSTAT+1
    93 3D45 85 A2		        sta zp_fn_bytes_hi
    94 3D47 AD EC 02		        lda DVSTAT+2
    95 3D4A 85 9F		        sta zp_fn_connected
    96 3D4C AD ED 02		        lda DVSTAT+3
    97 3D4F 85 A0		        sta zp_fn_error
    98
    99 3D51 18			        clc
   100 3D52 60			        rts
   101 3D53 38			?err    sec
   102 3D54 60			        rts
   103 				.endp
