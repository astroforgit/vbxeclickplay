   203 				; ----------------------------------------------------------------------------
   204 				; Macros
   205 				; ----------------------------------------------------------------------------
   206
   207 				; MEMAC B macros with shadow variable for interrupt-safe restore.
   208 				; IMPORTANT: Code using these macros MUST be below $4000!
   209 				; When MEMAC B is active, $4000-$7FFF reads VRAM, not RAM.
   210 				; Interrupt handlers use stubs at page 6 to disable/restore MEMAC B.
   211 				memb_on .macro
   212 				        lda #$80+:1
   213 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   214 				        ldy #VBXE_MEMAC_B
   215 				        sta (zp_vbxe_base),y
   216 				        .endm
   217
   218 				memb_off .macro
   219 				        lda #0
   220 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   221 				        ldy #VBXE_MEMAC_B
   222 				        sta (zp_vbxe_base),y
   223 				        .endm
   224
   225 				; Show message on status bar: :1=color, :2=message address
   226 				; Expands to subroutine call (9 bytes) instead of inline (31 bytes)
   227 				status_msg .macro
   228 				        ldy #:1
   229 				        lda #<:2
   230 				        ldx #>:2
   231 				        jsr status_msg_sub
   232 				        .endm
   233
   234 				; Wait N frames (RTCLOK-based delay): :1=frame count
   235 				; Expands to subroutine call (5 bytes) instead of inline (13 bytes)
   236 				wait_frames .macro
   237 				        ldx #:1
   238 				        jsr wait_frames_sub
   239 				        .endm
   240
   241 				blit_start .macro
   242 				        ldy #VBXE_BL_ADR0
   243 				        lda #<:1
   244 				        sta (zp_vbxe_base),y
   245 				        iny
   246 				        lda #>:1
   247 				        sta (zp_vbxe_base),y
   248 				        iny
   249 				        lda #0
   250 				        sta (zp_vbxe_base),y
   251 				        iny
   252 				        lda #1
   253 				        sta (zp_vbxe_base),y
   254 				        .endm
   255
   256 				blit_wait .macro
   257 				        ldy #VBXE_BLITTER
   258 				?bw     lda (zp_vbxe_base),y
   259 				        bne ?bw
   260 				        .endm
