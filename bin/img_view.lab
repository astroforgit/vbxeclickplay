   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 2FCC			.proc fn_read
   113 2FCC A5 A2		        lda zp_fn_bytes_hi
   114 2FCE D0 06		        bne ?max
   115 2FD0 A5 A1		        lda zp_fn_bytes_lo
   116 2FD2 F0 1E		        beq ?nothing
   117 2FD4 D0 0F		        bne ?use_lo
   118
   119 2FD6 A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 2FD8 85 A3		        sta zp_rx_len
   121 2FDA 8D 08 03		        sta DBYTLO
   122 2FDD A9 00		        lda #0
   123 2FDF 8D 09 03		        sta DBYTHI
   124 2FE2 4C F8 2F		        jmp ?do
   125
   126 2FE5 85 A3		?use_lo sta zp_rx_len
   127 2FE7 8D 08 03		        sta DBYTLO
   128 2FEA A9 00		        lda #0
   129 2FEC 8D 09 03		        sta DBYTHI
   130 2FEF 4C F8 2F		        jmp ?do
   131
   132 2FF2			?nothing
   133 2FF2 A9 00		        lda #0
   134 2FF4 85 A3		        sta zp_rx_len
   135 2FF6 18			        clc
   136 2FF7 60			        rts
   137
   138 2FF8 A9 71		?do     lda #FN_DEVID
   139 2FFA 8D 00 03		        sta DDEVIC
   140 2FFD AD 33 2F		        lda fn_cur_unit
   141 3000 8D 01 03		        sta DUNIT
   142 3003 A9 52		        lda #FN_CMD_READ
   143 3005 8D 02 03		        sta DCOMND
   144 3008 A9 40		        lda #SIO_READ
   145 300A 8D 03 03		        sta DSTATS
   146 300D A9 35		        lda #<rx_buffer
   147 300F 8D 04 03		        sta DBUFLO
   148 3012 A9 89		        lda #>rx_buffer
   149 3014 8D 05 03		        sta DBUFHI
   150 3017 A9 1E		        lda #FN_TIMEOUT
   151 3019 8D 06 03		        sta DTIMLO
   152 301C AD 08 03		        lda DBYTLO
   153 301F 8D 0A 03		        sta DAUX1
   154 3022 AD 09 03		        lda DBYTHI
   155 3025 8D 0B 03		        sta DAUX2
   156
   157 3028 20 59 E4		        jsr SIOV
   158 302B AD 03 03		        lda DSTATS
   159 302E 30 02		        bmi ?err
