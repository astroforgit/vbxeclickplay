   191 = 0098			zp_link_num    = $98
   192 				; $99-$9B free (removed: zp_in_heading, zp_in_list, zp_in_bold — write-only)
   193 = 009C			zp_in_skip     = $9C
   194 = 009D			zp_list_type   = $9D
   195 = 009E			zp_list_item   = $9E
