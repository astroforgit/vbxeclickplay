   104
   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 2E22			.proc fn_read
   113 2E22 A5 A2		        lda zp_fn_bytes_hi
   114 2E24 D0 06		        bne ?max
   115 2E26 A5 A1		        lda zp_fn_bytes_lo
   116 2E28 F0 1E		        beq ?nothing
   117 2E2A D0 0F		        bne ?use_lo
   118
   119 2E2C A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 2E2E 85 A3		        sta zp_rx_len
   121 2E30 8D 08 03		        sta DBYTLO
   122 2E33 A9 00		        lda #0
   123 2E35 8D 09 03		        sta DBYTHI
   124 2E38 4C 4E 2E		        jmp ?do
   125
   126 2E3B 85 A3		?use_lo sta zp_rx_len
   127 2E3D 8D 08 03		        sta DBYTLO
   128 2E40 A9 00		        lda #0
   129 2E42 8D 09 03		        sta DBYTHI
   130 2E45 4C 4E 2E		        jmp ?do
   131
   132 2E48			?nothing
   133 2E48 A9 00		        lda #0
   134 2E4A 85 A3		        sta zp_rx_len
   135 2E4C 18			        clc
   136 2E4D 60			        rts
   137
   138 2E4E A9 71		?do     lda #FN_DEVID
   139 2E50 8D 00 03		        sta DDEVIC
   140 2E53 AD 89 2D		        lda fn_cur_unit
   141 2E56 8D 01 03		        sta DUNIT
   142 2E59 A9 52		        lda #FN_CMD_READ
   143 2E5B 8D 02 03		        sta DCOMND
   144 2E5E A9 40		        lda #SIO_READ
   145 2E60 8D 03 03		        sta DSTATS
   146 2E63 A9 32		        lda #<rx_buffer
   147 2E65 8D 04 03		        sta DBUFLO
   148 2E68 A9 89		        lda #>rx_buffer
   149 2E6A 8D 05 03		        sta DBUFHI
   150 2E6D A9 1E		        lda #FN_TIMEOUT
   151 2E6F 8D 06 03		        sta DTIMLO
   152 2E72 AD 08 03		        lda DBYTLO
   153 2E75 8D 0A 03		        sta DAUX1
   154 2E78 AD 09 03		        lda DBYTHI
   155 2E7B 8D 0B 03		        sta DAUX2
   156
   157 2E7E 20 59 E4		        jsr SIOV
   158 2E81 AD 03 03		        lda DSTATS
   159 2E84 30 02		        bmi ?err
   160 2E86 18			        clc
   161 2E87 60			        rts
   162 2E88 38			?err    sec
   163 2E89 60			        rts
   164 				.endp
   165
   166 				; ----------------------------------------------------------------------------
   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 2E8A			.proc fn_close
   170 2E8A A9 71		        lda #FN_DEVID
   171 2E8C 8D 00 03		        sta DDEVIC
   172 2E8F AD 89 2D		        lda fn_cur_unit
   173 2E92 8D 01 03		        sta DUNIT
   174 2E95 A9 43		        lda #FN_CMD_CLOSE
   175 2E97 8D 02 03		        sta DCOMND
   176 2E9A A9 00		        lda #SIO_NONE
   177 2E9C 8D 03 03		        sta DSTATS
   178 2E9F A9 00		        lda #0
   179 2EA1 8D 04 03		        sta DBUFLO
   180 2EA4 8D 05 03		        sta DBUFHI
   181 2EA7 8D 08 03		        sta DBYTLO
   182 2EAA 8D 09 03		        sta DBYTHI
   183 2EAD 8D 0A 03		        sta DAUX1
   184 2EB0 8D 0B 03		        sta DAUX2
   185 2EB3 A9 1E		        lda #FN_TIMEOUT
   186 2EB5 8D 06 03		        sta DTIMLO
   187
   188 2EB8 4C 59 E4		        jmp SIOV
   189 				.endp
