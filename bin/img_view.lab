    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 2BD1			.proc fn_status
    65 2BD1 A9 71		        lda #FN_DEVID
    66 2BD3 8D 00 03		        sta DDEVIC
    67 2BD6 AD 8C 2B		        lda fn_cur_unit
    68 2BD9 8D 01 03		        sta DUNIT
    69 2BDC A9 53		        lda #FN_CMD_STATUS
    70 2BDE 8D 02 03		        sta DCOMND
    71 2BE1 A9 40		        lda #SIO_READ
    72 2BE3 8D 03 03		        sta DSTATS
    73 2BE6 A9 EA		        lda #<DVSTAT
    74 2BE8 8D 04 03		        sta DBUFLO
    75 2BEB A9 02		        lda #>DVSTAT
    76 2BED 8D 05 03		        sta DBUFHI
    77 2BF0 A9 1E		        lda #FN_TIMEOUT
    78 2BF2 8D 06 03		        sta DTIMLO
    79 2BF5 A9 04		        lda #4
    80 2BF7 8D 08 03		        sta DBYTLO
    81 2BFA A9 00		        lda #0
    82 2BFC 8D 09 03		        sta DBYTHI
    83 2BFF 8D 0A 03		        sta DAUX1
    84 2C02 8D 0B 03		        sta DAUX2
    85
    86 2C05 20 59 E4		        jsr SIOV
    87 2C08 AD 03 03		        lda DSTATS
    88 2C0B 30 16		        bmi ?err
    89
    90 2C0D AD EA 02		        lda DVSTAT
    91 2C10 85 A1		        sta zp_fn_bytes_lo
    92 2C12 AD EB 02		        lda DVSTAT+1
    93 2C15 85 A2		        sta zp_fn_bytes_hi
    94 2C17 AD EC 02		        lda DVSTAT+2
    95 2C1A 85 9F		        sta zp_fn_connected
    96 2C1C AD ED 02		        lda DVSTAT+3
    97 2C1F 85 A0		        sta zp_fn_error
    98
    99 2C21 18			        clc
   100 2C22 60			        rts
   101 2C23 38			?err    sec
   102 2C24 60			        rts
