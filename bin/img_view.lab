Source: fujinet.asm
     1 				; ============================================================================
     2 				; FujiNet N: Device SIO Layer
     3 				; ============================================================================
     4
     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 2D89 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
    13 = 0080			SIO_WRITE      = $80
    14 = 0000			SIO_NONE       = $00
    15 = 0004			FN_OPEN_READ   = 4
    16 = 0000			FN_TRANS_NONE  = 0
    17 = 001E			FN_TIMEOUT     = 30
    18 = 0100			URL_BUF_SIZE   = 256
    19 = 0100			RX_BUF_SIZE    = 256
    20
    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 2D8A			.proc fn_open
    26 2D8A A9 71		        lda #FN_DEVID
    27 2D8C 8D 00 03		        sta DDEVIC
    28 2D8F AD 89 2D		        lda fn_cur_unit
    29 2D92 8D 01 03		        sta DUNIT
    30 2D95 A9 4F		        lda #FN_CMD_OPEN
    31 2D97 8D 02 03		        sta DCOMND
    32 2D9A A9 80		        lda #SIO_WRITE
    33 2D9C 8D 03 03		        sta DSTATS
    34 2D9F A9 32		        lda #<url_buffer
    35 2DA1 8D 04 03		        sta DBUFLO
    36 2DA4 A9 88		        lda #>url_buffer
    37 2DA6 8D 05 03		        sta DBUFHI
    38 2DA9 A9 1E		        lda #FN_TIMEOUT
    39 2DAB 8D 06 03		        sta DTIMLO
    40 2DAE A9 00		        lda #<URL_BUF_SIZE
    41 2DB0 8D 08 03		        sta DBYTLO
    42 2DB3 A9 01		        lda #>URL_BUF_SIZE
    43 2DB5 8D 09 03		        sta DBYTHI
    44 2DB8 A9 04		        lda #FN_OPEN_READ
    45 2DBA 8D 0A 03		        sta DAUX1
    46 2DBD A9 00		        lda #FN_TRANS_NONE
    47 2DBF 8D 0B 03		        sta DAUX2
    48
    49 2DC2 20 59 E4		        jsr SIOV
    50 2DC5 AD 03 03		        lda DSTATS
    51 2DC8 30 02		        bmi ?err
    52 2DCA 18			        clc
    53 2DCB 60			        rts
    54 2DCC 38			?err    sec
    55 2DCD 60			        rts
    56 				.endp
    57
    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 2DCE			.proc fn_status
    65 2DCE A9 71		        lda #FN_DEVID
    66 2DD0 8D 00 03		        sta DDEVIC
    67 2DD3 AD 89 2D		        lda fn_cur_unit
    68 2DD6 8D 01 03		        sta DUNIT
    69 2DD9 A9 53		        lda #FN_CMD_STATUS
    70 2DDB 8D 02 03		        sta DCOMND
    71 2DDE A9 40		        lda #SIO_READ
    72 2DE0 8D 03 03		        sta DSTATS
    73 2DE3 A9 EA		        lda #<DVSTAT
    74 2DE5 8D 04 03		        sta DBUFLO
    75 2DE8 A9 02		        lda #>DVSTAT
    76 2DEA 8D 05 03		        sta DBUFHI
    77 2DED A9 1E		        lda #FN_TIMEOUT
    78 2DEF 8D 06 03		        sta DTIMLO
    79 2DF2 A9 04		        lda #4
    80 2DF4 8D 08 03		        sta DBYTLO
    81 2DF7 A9 00		        lda #0
    82 2DF9 8D 09 03		        sta DBYTHI
    83 2DFC 8D 0A 03		        sta DAUX1
    84 2DFF 8D 0B 03		        sta DAUX2
    85
    86 2E02 20 59 E4		        jsr SIOV
    87 2E05 AD 03 03		        lda DSTATS
    88 2E08 30 16		        bmi ?err
    89
    90 2E0A AD EA 02		        lda DVSTAT
    91 2E0D 85 A1		        sta zp_fn_bytes_lo
    92 2E0F AD EB 02		        lda DVSTAT+1
    93 2E12 85 A2		        sta zp_fn_bytes_hi
    94 2E14 AD EC 02		        lda DVSTAT+2
    95 2E17 85 9F		        sta zp_fn_connected
    96 2E19 AD ED 02		        lda DVSTAT+3
