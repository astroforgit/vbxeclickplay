    31 32BC 8D 02 03		        sta DCOMND
    32 32BF A9 80		        lda #SIO_WRITE
    33 32C1 8D 03 03		        sta DSTATS
    34 32C4 A9 80		        lda #<url_buffer
    35 32C6 8D 04 03		        sta DBUFLO
    36 32C9 A9 88		        lda #>url_buffer
    37 32CB 8D 05 03		        sta DBUFHI
    38 32CE A9 1E		        lda #FN_TIMEOUT
    39 32D0 8D 06 03		        sta DTIMLO
    40 32D3 A9 00		        lda #<URL_BUF_SIZE
