   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 2C25			.proc fn_read
   113 2C25 A5 A2		        lda zp_fn_bytes_hi
   114 2C27 D0 06		        bne ?max
   115 2C29 A5 A1		        lda zp_fn_bytes_lo
   116 2C2B F0 1E		        beq ?nothing
   117 2C2D D0 0F		        bne ?use_lo
   118
   119 2C2F A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 2C31 85 A3		        sta zp_rx_len
   121 2C33 8D 08 03		        sta DBYTLO
   122 2C36 A9 00		        lda #0
   123 2C38 8D 09 03		        sta DBYTHI
   124 2C3B 4C 51 2C		        jmp ?do
   125
   126 2C3E 85 A3		?use_lo sta zp_rx_len
   127 2C40 8D 08 03		        sta DBYTLO
   128 2C43 A9 00		        lda #0
   129 2C45 8D 09 03		        sta DBYTHI
   130 2C48 4C 51 2C		        jmp ?do
   131
   132 2C4B			?nothing
   133 2C4B A9 00		        lda #0
   134 2C4D 85 A3		        sta zp_rx_len
   135 2C4F 18			        clc
   136 2C50 60			        rts
   137
   138 2C51 A9 71		?do     lda #FN_DEVID
   139 2C53 8D 00 03		        sta DDEVIC
   140 2C56 AD 8C 2B		        lda fn_cur_unit
   141 2C59 8D 01 03		        sta DUNIT
   142 2C5C A9 52		        lda #FN_CMD_READ
   143 2C5E 8D 02 03		        sta DCOMND
   144 2C61 A9 40		        lda #SIO_READ
   145 2C63 8D 03 03		        sta DSTATS
   146 2C66 A9 27		        lda #<rx_buffer
   147 2C68 8D 04 03		        sta DBUFLO
   148 2C6B A9 89		        lda #>rx_buffer
   149 2C6D 8D 05 03		        sta DBUFHI
   150 2C70 A9 1E		        lda #FN_TIMEOUT
   151 2C72 8D 06 03		        sta DTIMLO
   152 2C75 AD 08 03		        lda DBYTLO
   153 2C78 8D 0A 03		        sta DAUX1
   154 2C7B AD 09 03		        lda DBYTHI
   155 2C7E 8D 0B 03		        sta DAUX2
   156
   157 2C81 20 59 E4		        jsr SIOV
   158 2C84 AD 03 03		        lda DSTATS
   159 2C87 30 02		        bmi ?err
   160 2C89 18			        clc
   161 2C8A 60			        rts
   162 2C8B 38			?err    sec
   163 2C8C 60			        rts
   164 				.endp
