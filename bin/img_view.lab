   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 2C8D			.proc fn_close
   170 2C8D A9 71		        lda #FN_DEVID
   171 2C8F 8D 00 03		        sta DDEVIC
   172 2C92 AD 8C 2B		        lda fn_cur_unit
   173 2C95 8D 01 03		        sta DUNIT
   174 2C98 A9 43		        lda #FN_CMD_CLOSE
   175 2C9A 8D 02 03		        sta DCOMND
   176 2C9D A9 00		        lda #SIO_NONE
   177 2C9F 8D 03 03		        sta DSTATS
   178 2CA2 A9 00		        lda #0
   179 2CA4 8D 04 03		        sta DBUFLO
   180 2CA7 8D 05 03		        sta DBUFHI
   181 2CAA 8D 08 03		        sta DBYTLO
   182 2CAD 8D 09 03		        sta DBYTHI
   183 2CB0 8D 0A 03		        sta DAUX1
   184 2CB3 8D 0B 03		        sta DAUX2
   185 2CB6 A9 1E		        lda #FN_TIMEOUT
   186 2CB8 8D 06 03		        sta DTIMLO
   187
   188 2CBB 4C 59 E4		        jmp SIOV
   189 				.endp
