    35 32A2 8D 04 03		        sta DBUFLO
    36 32A5 A9 88		        lda #>url_buffer
    37 32A7 8D 05 03		        sta DBUFHI
    38 32AA A9 1E		        lda #FN_TIMEOUT
    39 32AC 8D 06 03		        sta DTIMLO
    40 32AF A9 00		        lda #<URL_BUF_SIZE
    41 32B1 8D 08 03		        sta DBYTLO
    42 32B4 A9 01		        lda #>URL_BUF_SIZE
    43 32B6 8D 09 03		        sta DBYTHI
