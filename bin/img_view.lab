   220 				; ----------------------------------------------------------------------------
   221 				; Macros
   222 				; ----------------------------------------------------------------------------
   223
   224 				; MEMAC B macros with shadow variable for interrupt-safe restore.
   225 				; IMPORTANT: Code using these macros MUST be below $4000!
   226 				; When MEMAC B is active, $4000-$7FFF reads VRAM, not RAM.
   227 				; Interrupt handlers use stubs at page 6 to disable/restore MEMAC B.
   228 				memb_on .macro
   229 				        lda #$80+:1
   230 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   231 				        ldy #VBXE_MEMAC_B
   232 				        sta (zp_vbxe_base),y
   233 				        .endm
   234
   235 				memb_off .macro
   236 				        lda #0
   237 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   238 				        ldy #VBXE_MEMAC_B
   239 				        sta (zp_vbxe_base),y
   240 				        .endm
   241
   242 				; Show message on status bar: :1=color, :2=message address
   243 				; Expands to subroutine call (9 bytes) instead of inline (31 bytes)
   244 				status_msg .macro
   245 				        ldy #:1
   246 				        lda #<:2
   247 				        ldx #>:2
   248 				        jsr status_msg_sub
   249 				        .endm
   250
   251 				; Wait N frames (RTCLOK-based delay): :1=frame count
   252 				; Expands to subroutine call (5 bytes) instead of inline (13 bytes)
   253 				wait_frames .macro
   254 				        ldx #:1
   255 				        jsr wait_frames_sub
   256 				        .endm
   257
   258 				blit_start .macro
   259 				        ldy #VBXE_BL_ADR0
   260 				        lda #<:1
   261 				        sta (zp_vbxe_base),y
   262 				        iny
   263 				        lda #>:1
   264 				        sta (zp_vbxe_base),y
   265 				        iny
   266 				        lda #0
   267 				        sta (zp_vbxe_base),y
   268 				        iny
   269 				        lda #1
   270 				        sta (zp_vbxe_base),y
   271 				        .endm
   272
   273 				blit_wait .macro
   274 				        ldy #VBXE_BLITTER
   275 				?bw     lda (zp_vbxe_base),y
   276 				        bne ?bw
   277 				        .endm
