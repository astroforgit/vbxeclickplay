   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 3347			.proc fn_read
   113 3347 A5 A2		        lda zp_fn_bytes_hi
   114 3349 D0 06		        bne ?max
   115 334B A5 A1		        lda zp_fn_bytes_lo
   116 334D F0 1E		        beq ?nothing
   117 334F D0 0F		        bne ?use_lo
   118
   119 3351 A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 3353 85 A3		        sta zp_rx_len
   121 3355 8D 08 03		        sta DBYTLO
   122 3358 A9 00		        lda #0
   123 335A 8D 09 03		        sta DBYTHI
   124 335D 4C 73 33		        jmp ?do
   125
   126 3360 85 A3		?use_lo sta zp_rx_len
   127 3362 8D 08 03		        sta DBYTLO
   128 3365 A9 00		        lda #0
   129 3367 8D 09 03		        sta DBYTHI
   130 336A 4C 73 33		        jmp ?do
   131
   132 336D			?nothing
   133 336D A9 00		        lda #0
   134 336F 85 A3		        sta zp_rx_len
   135 3371 18			        clc
   136 3372 60			        rts
   137
   138 3373 A9 71		?do     lda #FN_DEVID
   139 3375 8D 00 03		        sta DDEVIC
   140 3378 AD AE 32		        lda fn_cur_unit
   141 337B 8D 01 03		        sta DUNIT
   142 337E A9 52		        lda #FN_CMD_READ
   143 3380 8D 02 03		        sta DCOMND
   144 3383 A9 40		        lda #SIO_READ
   145 3385 8D 03 03		        sta DSTATS
   146 3388 A9 80		        lda #<rx_buffer
   147 338A 8D 04 03		        sta DBUFLO
   148 338D A9 89		        lda #>rx_buffer
   149 338F 8D 05 03		        sta DBUFHI
   150 3392 A9 1E		        lda #FN_TIMEOUT
   151 3394 8D 06 03		        sta DTIMLO
   152 3397 AD 08 03		        lda DBYTLO
   153 339A 8D 0A 03		        sta DAUX1
   154 339D AD 09 03		        lda DBYTHI
   155 33A0 8D 0B 03		        sta DAUX2
   156
   157 33A3 20 59 E4		        jsr SIOV
   158 33A6 AD 03 03		        lda DSTATS
   159 33A9 30 02		        bmi ?err
   160 33AB 18			        clc
   161 33AC 60			        rts
   162 33AD 38			?err    sec
   163 33AE 60			        rts
   164 				.endp
