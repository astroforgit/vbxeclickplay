   226 				; ----------------------------------------------------------------------------
   227 				; Macros
   228 				; ----------------------------------------------------------------------------
   229
   230 				; MEMAC B macros with shadow variable for interrupt-safe restore.
   231 				; IMPORTANT: Code using these macros MUST be below $4000!
   232 				; When MEMAC B is active, $4000-$7FFF reads VRAM, not RAM.
   233 				; Interrupt handlers use stubs at page 6 to disable/restore MEMAC B.
   234 				memb_on .macro
   235 				        lda #$80+:1
   236 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   237 				        ldy #VBXE_MEMAC_B
   238 				        sta (zp_vbxe_base),y
   239 				        .endm
   240
   241 				memb_off .macro
   242 				        lda #0
   243 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   244 				        ldy #VBXE_MEMAC_B
   245 				        sta (zp_vbxe_base),y
   246 				        .endm
   247
   248 				; Show message on status bar: :1=color, :2=message address
   249 				; Expands to subroutine call (9 bytes) instead of inline (31 bytes)
   250 				status_msg .macro
   251 				        ldy #:1
   252 				        lda #<:2
   253 				        ldx #>:2
   254 				        jsr status_msg_sub
   255 				        .endm
   256
   257 				; Wait N frames (RTCLOK-based delay): :1=frame count
   258 				; Expands to subroutine call (5 bytes) instead of inline (13 bytes)
   259 				wait_frames .macro
   260 				        ldx #:1
   261 				        jsr wait_frames_sub
   262 				        .endm
   263
   264 				blit_start .macro
   265 				        ldy #VBXE_BL_ADR0
   266 				        lda #<:1
   267 				        sta (zp_vbxe_base),y
   268 				        iny
   269 				        lda #>:1
   270 				        sta (zp_vbxe_base),y
   271 				        iny
   272 				        lda #0
   273 				        sta (zp_vbxe_base),y
   274 				        iny
   275 				        lda #1
   276 				        sta (zp_vbxe_base),y
   277 				        .endm
   278
   279 				blit_wait .macro
   280 				        ldy #VBXE_BLITTER
   281 				?bw     lda (zp_vbxe_base),y
   282 				        bne ?bw
   283 				        .endm
