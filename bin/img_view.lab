   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 2F4C			.proc fn_close
   170 2F4C A9 71		        lda #FN_DEVID
   171 2F4E 8D 00 03		        sta DDEVIC
   172 2F51 AD 4B 2E		        lda fn_cur_unit
   173 2F54 8D 01 03		        sta DUNIT
   174 2F57 A9 43		        lda #FN_CMD_CLOSE
   175 2F59 8D 02 03		        sta DCOMND
   176 2F5C A9 00		        lda #SIO_NONE
   177 2F5E 8D 03 03		        sta DSTATS
   178 2F61 A9 00		        lda #0
   179 2F63 8D 04 03		        sta DBUFLO
   180 2F66 8D 05 03		        sta DBUFHI
   181 2F69 8D 08 03		        sta DBYTLO
   182 2F6C 8D 09 03		        sta DBYTHI
   183 2F6F 8D 0A 03		        sta DAUX1
   184 2F72 8D 0B 03		        sta DAUX2
   185 2F75 A9 1E		        lda #FN_TIMEOUT
   186 2F77 8D 06 03		        sta DTIMLO
   187
   188 2F7A 4C 59 E4		        jmp SIOV
   189 				.endp
