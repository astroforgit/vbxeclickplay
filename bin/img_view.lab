    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 32F3			.proc fn_status
    65 32F3 A9 71		        lda #FN_DEVID
    66 32F5 8D 00 03		        sta DDEVIC
    67 32F8 AD AE 32		        lda fn_cur_unit
    68 32FB 8D 01 03		        sta DUNIT
    69 32FE A9 53		        lda #FN_CMD_STATUS
    70 3300 8D 02 03		        sta DCOMND
    71 3303 A9 40		        lda #SIO_READ
    72 3305 8D 03 03		        sta DSTATS
    73 3308 A9 EA		        lda #<DVSTAT
    74 330A 8D 04 03		        sta DBUFLO
    75 330D A9 02		        lda #>DVSTAT
    76 330F 8D 05 03		        sta DBUFHI
    77 3312 A9 1E		        lda #FN_TIMEOUT
    78 3314 8D 06 03		        sta DTIMLO
    79 3317 A9 04		        lda #4
    80 3319 8D 08 03		        sta DBYTLO
    81 331C A9 00		        lda #0
    82 331E 8D 09 03		        sta DBYTHI
    83 3321 8D 0A 03		        sta DAUX1
    84 3324 8D 0B 03		        sta DAUX2
    85
    86 3327 20 59 E4		        jsr SIOV
    87 332A AD 03 03		        lda DSTATS
    88 332D 30 16		        bmi ?err
    89
    90 332F AD EA 02		        lda DVSTAT
    91 3332 85 A1		        sta zp_fn_bytes_lo
    92 3334 AD EB 02		        lda DVSTAT+1
    93 3337 85 A2		        sta zp_fn_bytes_hi
    94 3339 AD EC 02		        lda DVSTAT+2
    95 333C 85 9F		        sta zp_fn_connected
    96 333E AD ED 02		        lda DVSTAT+3
    97 3341 85 A0		        sta zp_fn_error
