    92 332C AD EB 02		        lda DVSTAT+1
    93 332F 85 A2		        sta zp_fn_bytes_hi
    94 3331 AD EC 02		        lda DVSTAT+2
    95 3334 85 9F		        sta zp_fn_connected
    96 3336 AD ED 02		        lda DVSTAT+3
    97 3339 85 A0		        sta zp_fn_error
