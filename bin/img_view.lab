    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 2B8D			.proc fn_open
    26 2B8D A9 71		        lda #FN_DEVID
    27 2B8F 8D 00 03		        sta DDEVIC
    28 2B92 AD 8C 2B		        lda fn_cur_unit
    29 2B95 8D 01 03		        sta DUNIT
    30 2B98 A9 4F		        lda #FN_CMD_OPEN
    31 2B9A 8D 02 03		        sta DCOMND
    32 2B9D A9 80		        lda #SIO_WRITE
    33 2B9F 8D 03 03		        sta DSTATS
    34 2BA2 A9 27		        lda #<url_buffer
    35 2BA4 8D 04 03		        sta DBUFLO
    36 2BA7 A9 88		        lda #>url_buffer
    37 2BA9 8D 05 03		        sta DBUFHI
    38 2BAC A9 1E		        lda #FN_TIMEOUT
    39 2BAE 8D 06 03		        sta DTIMLO
    40 2BB1 A9 00		        lda #<URL_BUF_SIZE
    41 2BB3 8D 08 03		        sta DBYTLO
    42 2BB6 A9 01		        lda #>URL_BUF_SIZE
    43 2BB8 8D 09 03		        sta DBYTHI
    44 2BBB A9 04		        lda #FN_OPEN_READ
    45 2BBD 8D 0A 03		        sta DAUX1
    46 2BC0 A9 00		        lda #FN_TRANS_NONE
    47 2BC2 8D 0B 03		        sta DAUX2
    48
    49 2BC5 20 59 E4		        jsr SIOV
    50 2BC8 AD 03 03		        lda DSTATS
    51 2BCB 30 02		        bmi ?err
    52 2BCD 18			        clc
    53 2BCE 60			        rts
    54 2BCF 38			?err    sec
    55 2BD0 60			        rts
    56 				.endp
