    73 3300 A9 EA		        lda #<DVSTAT
    74 3302 8D 04 03		        sta DBUFLO
    75 3305 A9 02		        lda #>DVSTAT
    76 3307 8D 05 03		        sta DBUFHI
    77 330A A9 1E		        lda #FN_TIMEOUT
    78 330C 8D 06 03		        sta DTIMLO
    79 330F A9 04		        lda #4
    80 3311 8D 08 03		        sta DBYTLO
    81 3314 A9 00		        lda #0
    82 3316 8D 09 03		        sta DBYTHI
    83 3319 8D 0A 03		        sta DAUX1
    84 331C 8D 0B 03		        sta DAUX2
    85
    86 331F 20 59 E4		        jsr SIOV
    87 3322 AD 03 03		        lda DSTATS
    88 3325 30 16		        bmi ?err
    89
    90 3327 AD EA 02		        lda DVSTAT
