     1 				; ============================================================================
     2 				; VBXE Constants, Register Offsets, and Macros
     3 				; For VBXE Web Browser - Atari XE/XL
     4 				; Assembler: MADS
     5 				; ============================================================================
     6
     7 				; ----------------------------------------------------------------------------
     8 				; VBXE Register Offsets (from base $D640 or $D740)
     9 				; ----------------------------------------------------------------------------
    10
    11 = 0040			VBXE_VCTL      = $40   ; VIDEO_CONTROL (R/W)
    12 = 0040			VBXE_CORE_VER  = $40   ; CORE_VERSION (R) - same offset, read = version
    13
    14 = 0041			VBXE_XDL_ADR0  = $41   ; XDL address low byte (W)
    15 = 0042			VBXE_XDL_ADR1  = $42   ; XDL address mid byte (W) — not used (INY from ADR0), kept for HW reference
    16 = 0043			VBXE_XDL_ADR2  = $43   ; XDL address high byte (W) — not used (INY from ADR0), kept for HW reference
    17
    18 = 0044			VBXE_CSEL      = $44   ; Color Select (index 0-255)
    19 = 0045			VBXE_PSEL      = $45   ; Palette Select (0=playfield, 1=overlay)
    20 = 0046			VBXE_CR        = $46   ; Color Red component
    21 = 0047			VBXE_CG        = $47   ; Color Green component
    22 = 0048			VBXE_CB        = $48   ; Color Blue component
    23
    24 = 0050			VBXE_BL_ADR0   = $50   ; BCB address low
    25 = 0053			VBXE_BLITTER   = $53   ; Write $01=start, Read: non-zero=busy
    26
    27 = 005D			VBXE_MEMAC_B   = $5D   ; MEMAC B control (window $4000-$7FFF)
    28
    29 				; VIDEO_CONTROL bits
    30 = 0001			VC_XDL_ENABLED = $01
    31 = 0002			VC_XCOLOR      = $02
    32
    33 = 0010			FX_CORE_VER    = $10   ; Expected CORE_VERSION for FX core
    34
    35 				; ----------------------------------------------------------------------------
    36 				; XDL Control Word Flags
    37 				; ----------------------------------------------------------------------------
    38 = 0001			XDLC_TMON     = $0001
    39 = 0002			XDLC_GMON     = $0002
    40 = 0004			XDLC_OVOFF    = $0004
    41 = 0010			XDLC_MAPOFF   = $0010
    42 = 0020			XDLC_RPTL     = $0020
    43 = 0040			XDLC_OVADR    = $0040
    44 = 0100			XDLC_CHBASE   = $0100
    45 = 0800			XDLC_OVATT    = $0800
    46 = 8000			XDLC_END      = $8000
    47
    48 				; ----------------------------------------------------------------------------
    49 				; VBXE VRAM Layout
    50 				; ----------------------------------------------------------------------------
    51 = 8000			VRAM_IMG_BASE  = $8000  ; Image viewer: pixel data start (fits 320x240 @8bpp within 128KB VRAM)
    52 = 7A00			ROOM_SELECTION_CACHE_MEMB = $7A00 ; MEMAC B address for cached selection patches (VRAM $17A00)
    53 = 0005			ROOM_SELECTION_CACHE_BANK = 5     ; VBXE bank containing ROOM_SELECTION_CACHE_MEMB
    54 = 4C00			ROOM_SELECTION_CACHE_MAX  = $4C00 ; 19456 bytes reserved for selection-patch cache
    55 = 4600			ROOM_PATCH_CACHE_MEMB = $4600     ; MEMAC B address for cached pre-patch pixels (VRAM $1C600)
    56 = 0007			ROOM_PATCH_CACHE_BANK = 7         ; VBXE bank containing ROOM_PATCH_CACHE_MEMB
    57 = 3A00			ROOM_PATCH_CACHE_MAX  = $3A00     ; 14848 bytes reserved for original-background undo cache
    58 = 0000			VRAM_SCREEN    = $0000  ; Screen: SCR_ROWS*160 bytes (4800 for 30 rows)
    59 = 1300			VRAM_BCB       = $1300  ; BCB blocks (after screen)
    60 = 1380			VRAM_PATTERN   = $1380  ; Fill pattern (2 bytes)
    61 = 1400			VRAM_XDL       = $1400  ; XDL
    62 = 2000			VRAM_FONT      = $2000  ; Font: 256*8 = 2048 bytes
    63 = 0005			PAGE_BUF_BANK  = 5      ; VRAM $14000 >> 14 = 5
    64
    65 				; CPU addresses when MEMAC B bank 0 active ($4000 + VRAM offset)
    66 = 4000			MEMB_BASE      = $4000
    67 = 4000			MEMB_SCREEN    = $4000
    68 = 5300			MEMB_BCB       = $5300
    69 = 5380			MEMB_PATTERN   = $5380
    70 = 5400			MEMB_XDL       = $5400
    71 = 6000			MEMB_FONT      = $6000
    72
    73 				; Screen dimensions
    74 = 0050			SCR_COLS       = 80
    75 = 001D			SCR_ROWS       = 29
    76 = 00A0			SCR_STRIDE     = 160    ; 80 chars + 80 attrs
    77 = 0004			CHBASE_VAL     = 4      ; VRAM_FONT / $800
    78
    79 				; Content area (derived from SCR_ROWS)
    80 = 0002			CONTENT_TOP    = 2
    81 = 001A			CONTENT_BOT    = SCR_ROWS - 3
    82 = 0019			CONTENT_ROWS   = SCR_ROWS - 4
    83 = 0000			URL_ROW        = 0
    84 = 0001			TITLE_ROW      = 1
    85 = 001B			STATUS_ROW     = SCR_ROWS - 2
