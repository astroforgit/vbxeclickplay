   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 333F			.proc fn_read
   113 333F A5 A2		        lda zp_fn_bytes_hi
   114 3341 D0 06		        bne ?max
   115 3343 A5 A1		        lda zp_fn_bytes_lo
   116 3345 F0 1E		        beq ?nothing
   117 3347 D0 0F		        bne ?use_lo
   118
   119 3349 A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 334B 85 A3		        sta zp_rx_len
   121 334D 8D 08 03		        sta DBYTLO
   122 3350 A9 00		        lda #0
   123 3352 8D 09 03		        sta DBYTHI
   124 3355 4C 6B 33		        jmp ?do
   125
   126 3358 85 A3		?use_lo sta zp_rx_len
   127 335A 8D 08 03		        sta DBYTLO
   128 335D A9 00		        lda #0
   129 335F 8D 09 03		        sta DBYTHI
   130 3362 4C 6B 33		        jmp ?do
   131
   132 3365			?nothing
   133 3365 A9 00		        lda #0
   134 3367 85 A3		        sta zp_rx_len
   135 3369 18			        clc
   136 336A 60			        rts
   137
   138 336B A9 71		?do     lda #FN_DEVID
   139 336D 8D 00 03		        sta DDEVIC
   140 3370 AD A6 32		        lda fn_cur_unit
   141 3373 8D 01 03		        sta DUNIT
   142 3376 A9 52		        lda #FN_CMD_READ
   143 3378 8D 02 03		        sta DCOMND
   144 337B A9 40		        lda #SIO_READ
   145 337D 8D 03 03		        sta DSTATS
   146 3380 A9 60		        lda #<rx_buffer
   147 3382 8D 04 03		        sta DBUFLO
   148 3385 A9 89		        lda #>rx_buffer
   149 3387 8D 05 03		        sta DBUFHI
   150 338A A9 1E		        lda #FN_TIMEOUT
   151 338C 8D 06 03		        sta DTIMLO
   152 338F AD 08 03		        lda DBYTLO
   153 3392 8D 0A 03		        sta DAUX1
   154 3395 AD 09 03		        lda DBYTHI
   155 3398 8D 0B 03		        sta DAUX2
   156
   157 339B 20 59 E4		        jsr SIOV
   158 339E AD 03 03		        lda DSTATS
   159 33A1 30 02		        bmi ?err
   160 33A3 18			        clc
