   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 2FAE			.proc fn_read
   113 2FAE A5 A2		        lda zp_fn_bytes_hi
   114 2FB0 D0 06		        bne ?max
   115 2FB2 A5 A1		        lda zp_fn_bytes_lo
   116 2FB4 F0 1E		        beq ?nothing
   117 2FB6 D0 0F		        bne ?use_lo
   118
   119 2FB8 A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 2FBA 85 A3		        sta zp_rx_len
   121 2FBC 8D 08 03		        sta DBYTLO
   122 2FBF A9 00		        lda #0
   123 2FC1 8D 09 03		        sta DBYTHI
   124 2FC4 4C DA 2F		        jmp ?do
   125
   126 2FC7 85 A3		?use_lo sta zp_rx_len
   127 2FC9 8D 08 03		        sta DBYTLO
   128 2FCC A9 00		        lda #0
   129 2FCE 8D 09 03		        sta DBYTHI
   130 2FD1 4C DA 2F		        jmp ?do
   131
   132 2FD4			?nothing
   133 2FD4 A9 00		        lda #0
   134 2FD6 85 A3		        sta zp_rx_len
   135 2FD8 18			        clc
   136 2FD9 60			        rts
   137
   138 2FDA A9 71		?do     lda #FN_DEVID
   139 2FDC 8D 00 03		        sta DDEVIC
   140 2FDF AD 15 2F		        lda fn_cur_unit
   141 2FE2 8D 01 03		        sta DUNIT
   142 2FE5 A9 52		        lda #FN_CMD_READ
   143 2FE7 8D 02 03		        sta DCOMND
   144 2FEA A9 40		        lda #SIO_READ
   145 2FEC 8D 03 03		        sta DSTATS
   146 2FEF A9 33		        lda #<rx_buffer
   147 2FF1 8D 04 03		        sta DBUFLO
   148 2FF4 A9 89		        lda #>rx_buffer
   149 2FF6 8D 05 03		        sta DBUFHI
   150 2FF9 A9 1E		        lda #FN_TIMEOUT
   151 2FFB 8D 06 03		        sta DTIMLO
   152 2FFE AD 08 03		        lda DBYTLO
   153 3001 8D 0A 03		        sta DAUX1
   154 3004 AD 09 03		        lda DBYTHI
   155 3007 8D 0B 03		        sta DAUX2
   156
   157 300A 20 59 E4		        jsr SIOV
   158 300D AD 03 03		        lda DSTATS
   159 3010 30 02		        bmi ?err
   160 3012 18			        clc
   161 3013 60			        rts
   162 3014 38			?err    sec
   163 3015 60			        rts
   164 				.endp
