     1 				; ============================================================================
     2 				; FujiNet N: Device SIO Layer
     3 				; ============================================================================
     4
     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 3DBA 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
    13 = 0080			SIO_WRITE      = $80
    14 = 0000			SIO_NONE       = $00
    15 = 0004			FN_OPEN_READ   = 4
    16 = 0000			FN_TRANS_NONE  = 0
    17 = 001E			FN_TIMEOUT     = 30
    18 = 0100			URL_BUF_SIZE   = 256
    19 = 0100			RX_BUF_SIZE    = 256
    20
    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 3DBB			.proc fn_open
    26 3DBB A9 71		        lda #FN_DEVID
    27 3DBD 8D 00 03		        sta DDEVIC
    28 3DC0 AD BA 3D		        lda fn_cur_unit
    29 3DC3 8D 01 03		        sta DUNIT
    30 3DC6 A9 4F		        lda #FN_CMD_OPEN
    31 3DC8 8D 02 03		        sta DCOMND
    32 3DCB A9 80		        lda #SIO_WRITE
    33 3DCD 8D 03 03		        sta DSTATS
    34 3DD0 A9 FE		        lda #<url_buffer
    35 3DD2 8D 04 03		        sta DBUFLO
    36 3DD5 A9 88		        lda #>url_buffer
    37 3DD7 8D 05 03		        sta DBUFHI
    38 3DDA A9 1E		        lda #FN_TIMEOUT
    39 3DDC 8D 06 03		        sta DTIMLO
    40 3DDF A9 00		        lda #<URL_BUF_SIZE
    41 3DE1 8D 08 03		        sta DBYTLO
    42 3DE4 A9 01		        lda #>URL_BUF_SIZE
    43 3DE6 8D 09 03		        sta DBYTHI
    44 3DE9 A9 04		        lda #FN_OPEN_READ
    45 3DEB 8D 0A 03		        sta DAUX1
    46 3DEE A9 00		        lda #FN_TRANS_NONE
    47 3DF0 8D 0B 03		        sta DAUX2
