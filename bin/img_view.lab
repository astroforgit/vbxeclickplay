    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 2F5A			.proc fn_status
    65 2F5A A9 71		        lda #FN_DEVID
    66 2F5C 8D 00 03		        sta DDEVIC
    67 2F5F AD 15 2F		        lda fn_cur_unit
    68 2F62 8D 01 03		        sta DUNIT
    69 2F65 A9 53		        lda #FN_CMD_STATUS
    70 2F67 8D 02 03		        sta DCOMND
    71 2F6A A9 40		        lda #SIO_READ
    72 2F6C 8D 03 03		        sta DSTATS
    73 2F6F A9 EA		        lda #<DVSTAT
    74 2F71 8D 04 03		        sta DBUFLO
    75 2F74 A9 02		        lda #>DVSTAT
    76 2F76 8D 05 03		        sta DBUFHI
    77 2F79 A9 1E		        lda #FN_TIMEOUT
    78 2F7B 8D 06 03		        sta DTIMLO
    79 2F7E A9 04		        lda #4
    80 2F80 8D 08 03		        sta DBYTLO
    81 2F83 A9 00		        lda #0
    82 2F85 8D 09 03		        sta DBYTHI
    83 2F88 8D 0A 03		        sta DAUX1
    84 2F8B 8D 0B 03		        sta DAUX2
    85
    86 2F8E 20 59 E4		        jsr SIOV
    87 2F91 AD 03 03		        lda DSTATS
    88 2F94 30 16		        bmi ?err
    89
    90 2F96 AD EA 02		        lda DVSTAT
    91 2F99 85 A1		        sta zp_fn_bytes_lo
    92 2F9B AD EB 02		        lda DVSTAT+1
    93 2F9E 85 A2		        sta zp_fn_bytes_hi
    94 2FA0 AD EC 02		        lda DVSTAT+2
    95 2FA3 85 9F		        sta zp_fn_connected
    96 2FA5 AD ED 02		        lda DVSTAT+3
    97 2FA8 85 A0		        sta zp_fn_error
    98
    99 2FAA 18			        clc
   100 2FAB 60			        rts
   101 2FAC 38			?err    sec
   102 2FAD 60			        rts
   103 				.endp
