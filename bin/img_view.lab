   205 				; $A7-$A8 free (removed: zp_page_lines — write-only)
   206 = 00A9			zp_hist_ptr    = $A9   ; 1 byte - history stack index (0-7)
   207 				; $AA free (removed: zp_fn_got_data — never referenced)
   208 = 00AB			zp_img_ptr     = $AB   ; 2 bytes - image write pointer (MEMAC B window)
   209 = 00AD			zp_memb_shadow = $AD   ; MEMAC B shadow for NMI-safe restore
   210 = 00AE			zp_tirq_saved  = $AE   ; Timer IRQ: saved shadow value
   211 = 00AF			zp_vbi_saved   = $AF   ; VBI: saved shadow value
   212
   213 				; Page buffer pointers ($B8-$BB, after mouse $B0-$B7)
   214 = 00B8			zp_pb_wr_ptr   = $B8   ; 2B write pointer (MEMAC B window $4000-$7FFF)
   215 = 00BA			zp_pb_rd_ptr   = $BA   ; 2B read pointer
   216
   217 				; TAB navigation ($BC)
   218 = 00BC			zp_tab_link    = $BC   ; currently selected link via TAB ($FF = none)
