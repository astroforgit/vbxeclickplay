    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 2F78			.proc fn_status
    65 2F78 A9 71		        lda #FN_DEVID
    66 2F7A 8D 00 03		        sta DDEVIC
    67 2F7D AD 33 2F		        lda fn_cur_unit
    68 2F80 8D 01 03		        sta DUNIT
    69 2F83 A9 53		        lda #FN_CMD_STATUS
    70 2F85 8D 02 03		        sta DCOMND
    71 2F88 A9 40		        lda #SIO_READ
    72 2F8A 8D 03 03		        sta DSTATS
    73 2F8D A9 EA		        lda #<DVSTAT
    74 2F8F 8D 04 03		        sta DBUFLO
    75 2F92 A9 02		        lda #>DVSTAT
    76 2F94 8D 05 03		        sta DBUFHI
    77 2F97 A9 1E		        lda #FN_TIMEOUT
    78 2F99 8D 06 03		        sta DTIMLO
    79 2F9C A9 04		        lda #4
    80 2F9E 8D 08 03		        sta DBYTLO
    81 2FA1 A9 00		        lda #0
    82 2FA3 8D 09 03		        sta DBYTHI
    83 2FA6 8D 0A 03		        sta DAUX1
    84 2FA9 8D 0B 03		        sta DAUX2
    85
    86 2FAC 20 59 E4		        jsr SIOV
    87 2FAF AD 03 03		        lda DSTATS
    88 2FB2 30 16		        bmi ?err
    89
    90 2FB4 AD EA 02		        lda DVSTAT
    91 2FB7 85 A1		        sta zp_fn_bytes_lo
    92 2FB9 AD EB 02		        lda DVSTAT+1
    93 2FBC 85 A2		        sta zp_fn_bytes_hi
    94 2FBE AD EC 02		        lda DVSTAT+2
    95 2FC1 85 9F		        sta zp_fn_connected
    96 2FC3 AD ED 02		        lda DVSTAT+3
    97 2FC6 85 A0		        sta zp_fn_error
