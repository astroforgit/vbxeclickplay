    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 32CF			.proc fn_status
    65 32CF A9 71		        lda #FN_DEVID
    66 32D1 8D 00 03		        sta DDEVIC
    67 32D4 AD 8A 32		        lda fn_cur_unit
    68 32D7 8D 01 03		        sta DUNIT
    69 32DA A9 53		        lda #FN_CMD_STATUS
    70 32DC 8D 02 03		        sta DCOMND
    71 32DF A9 40		        lda #SIO_READ
    72 32E1 8D 03 03		        sta DSTATS
    73 32E4 A9 EA		        lda #<DVSTAT
    74 32E6 8D 04 03		        sta DBUFLO
    75 32E9 A9 02		        lda #>DVSTAT
    76 32EB 8D 05 03		        sta DBUFHI
    77 32EE A9 1E		        lda #FN_TIMEOUT
    78 32F0 8D 06 03		        sta DTIMLO
    79 32F3 A9 04		        lda #4
    80 32F5 8D 08 03		        sta DBYTLO
    81 32F8 A9 00		        lda #0
    82 32FA 8D 09 03		        sta DBYTHI
    83 32FD 8D 0A 03		        sta DAUX1
    84 3300 8D 0B 03		        sta DAUX2
    85
    86 3303 20 59 E4		        jsr SIOV
    87 3306 AD 03 03		        lda DSTATS
    88 3309 30 16		        bmi ?err
    89
    90 330B AD EA 02		        lda DVSTAT
    91 330E 85 A1		        sta zp_fn_bytes_lo
    92 3310 AD EB 02		        lda DVSTAT+1
    93 3313 85 A2		        sta zp_fn_bytes_hi
    94 3315 AD EC 02		        lda DVSTAT+2
    95 3318 85 9F		        sta zp_fn_connected
    96 331A AD ED 02		        lda DVSTAT+3
    97 331D 85 A0		        sta zp_fn_error
