    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 3DFF			.proc fn_status
    65 3DFF A9 71		        lda #FN_DEVID
    66 3E01 8D 00 03		        sta DDEVIC
    67 3E04 AD BA 3D		        lda fn_cur_unit
    68 3E07 8D 01 03		        sta DUNIT
    69 3E0A A9 53		        lda #FN_CMD_STATUS
    70 3E0C 8D 02 03		        sta DCOMND
    71 3E0F A9 40		        lda #SIO_READ
    72 3E11 8D 03 03		        sta DSTATS
    73 3E14 A9 EA		        lda #<DVSTAT
    74 3E16 8D 04 03		        sta DBUFLO
    75 3E19 A9 02		        lda #>DVSTAT
    76 3E1B 8D 05 03		        sta DBUFHI
    77 3E1E A9 1E		        lda #FN_TIMEOUT
    78 3E20 8D 06 03		        sta DTIMLO
    79 3E23 A9 04		        lda #4
    80 3E25 8D 08 03		        sta DBYTLO
    81 3E28 A9 00		        lda #0
    82 3E2A 8D 09 03		        sta DBYTHI
    83 3E2D 8D 0A 03		        sta DAUX1
    84 3E30 8D 0B 03		        sta DAUX2
    85
    86 3E33 20 59 E4		        jsr SIOV
    87 3E36 AD 03 03		        lda DSTATS
    88 3E39 30 16		        bmi ?err
    89
    90 3E3B AD EA 02		        lda DVSTAT
    91 3E3E 85 A1		        sta zp_fn_bytes_lo
    92 3E40 AD EB 02		        lda DVSTAT+1
    93 3E43 85 A2		        sta zp_fn_bytes_hi
    94 3E45 AD EC 02		        lda DVSTAT+2
    95 3E48 85 9F		        sta zp_fn_connected
    96 3E4A AD ED 02		        lda DVSTAT+3
    97 3E4D 85 A0		        sta zp_fn_error
    98
    99 3E4F 18			        clc
   100 3E50 60			        rts
   101 3E51 38			?err    sec
   102 3E52 60			        rts
   103 				.endp
   104
   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 3E53			.proc fn_read
   113 3E53 A5 A2		        lda zp_fn_bytes_hi
   114 3E55 D0 06		        bne ?max
   115 3E57 A5 A1		        lda zp_fn_bytes_lo
   116 3E59 F0 1E		        beq ?nothing
   117 3E5B D0 0F		        bne ?use_lo
   118
   119 3E5D A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 3E5F 85 A3		        sta zp_rx_len
   121 3E61 8D 08 03		        sta DBYTLO
   122 3E64 A9 00		        lda #0
   123 3E66 8D 09 03		        sta DBYTHI
   124 3E69 4C 7F 3E		        jmp ?do
   125
   126 3E6C 85 A3		?use_lo sta zp_rx_len
   127 3E6E 8D 08 03		        sta DBYTLO
   128 3E71 A9 00		        lda #0
   129 3E73 8D 09 03		        sta DBYTHI
   130 3E76 4C 7F 3E		        jmp ?do
   131
   132 3E79			?nothing
   133 3E79 A9 00		        lda #0
   134 3E7B 85 A3		        sta zp_rx_len
   135 3E7D 18			        clc
   136 3E7E 60			        rts
   137
   138 3E7F A9 71		?do     lda #FN_DEVID
   139 3E81 8D 00 03		        sta DDEVIC
   140 3E84 AD BA 3D		        lda fn_cur_unit
   141 3E87 8D 01 03		        sta DUNIT
   142 3E8A A9 52		        lda #FN_CMD_READ
   143 3E8C 8D 02 03		        sta DCOMND
   144 3E8F A9 40		        lda #SIO_READ
   145 3E91 8D 03 03		        sta DSTATS
   146 3E94 A9 FE		        lda #<rx_buffer
   147 3E96 8D 04 03		        sta DBUFLO
   148 3E99 A9 89		        lda #>rx_buffer
   149 3E9B 8D 05 03		        sta DBUFHI
   150 3E9E A9 1E		        lda #FN_TIMEOUT
   151 3EA0 8D 06 03		        sta DTIMLO
   152 3EA3 AD 08 03		        lda DBYTLO
   153 3EA6 8D 0A 03		        sta DAUX1
   154 3EA9 AD 09 03		        lda DBYTHI
   155 3EAC 8D 0B 03		        sta DAUX2
   156
   157 3EAF 20 59 E4		        jsr SIOV
   158 3EB2 AD 03 03		        lda DSTATS
   159 3EB5 30 02		        bmi ?err
   160 3EB7 18			        clc
   161 3EB8 60			        rts
   162 3EB9 38			?err    sec
   163 3EBA 60			        rts
   164 				.endp
   165
   166 				; ----------------------------------------------------------------------------
   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 3EBB			.proc fn_close
   170 3EBB A9 71		        lda #FN_DEVID
   171 3EBD 8D 00 03		        sta DDEVIC
   172 3EC0 AD BA 3D		        lda fn_cur_unit
   173 3EC3 8D 01 03		        sta DUNIT
   174 3EC6 A9 43		        lda #FN_CMD_CLOSE
   175 3EC8 8D 02 03		        sta DCOMND
   176 3ECB A9 00		        lda #SIO_NONE
   177 3ECD 8D 03 03		        sta DSTATS
   178 3ED0 A9 00		        lda #0
   179 3ED2 8D 04 03		        sta DBUFLO
   180 3ED5 8D 05 03		        sta DBUFHI
   181 3ED8 8D 08 03		        sta DBYTLO
   182 3EDB 8D 09 03		        sta DBYTHI
   183 3EDE 8D 0A 03		        sta DAUX1
   184 3EE1 8D 0B 03		        sta DAUX2
   185 3EE4 A9 1E		        lda #FN_TIMEOUT
   186 3EE6 8D 06 03		        sta DTIMLO
   187
   188 3EE9 4C 59 E4		        jmp SIOV
   189 				.endp
