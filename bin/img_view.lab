   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 3016			.proc fn_close
   170 3016 A9 71		        lda #FN_DEVID
   171 3018 8D 00 03		        sta DDEVIC
   172 301B AD 15 2F		        lda fn_cur_unit
   173 301E 8D 01 03		        sta DUNIT
   174 3021 A9 43		        lda #FN_CMD_CLOSE
   175 3023 8D 02 03		        sta DCOMND
   176 3026 A9 00		        lda #SIO_NONE
   177 3028 8D 03 03		        sta DSTATS
   178 302B A9 00		        lda #0
   179 302D 8D 04 03		        sta DBUFLO
   180 3030 8D 05 03		        sta DBUFHI
   181 3033 8D 08 03		        sta DBYTLO
   182 3036 8D 09 03		        sta DBYTHI
   183 3039 8D 0A 03		        sta DAUX1
   184 303C 8D 0B 03		        sta DAUX2
   185 303F A9 1E		        lda #FN_TIMEOUT
   186 3041 8D 06 03		        sta DTIMLO
   187
   188 3044 4C 59 E4		        jmp SIOV
