    95 = 000F			COL_LIME       = 15   ; sub
    96
    97 = 0001			ATTR_NORMAL    = COL_WHITE
    98 = 0002			ATTR_LINK      = COL_BLUE     ; basic link color (for UI elements)
    99 = 0020			ATTR_LINK_BASE = $20          ; link attrs: $20+link_num (palette $20-$5F = blue)
   100 = 0003			ATTR_HEADING   = COL_ORANGE
   101 = 0007			ATTR_H1        = COL_YELLOW
   102 = 0003			ATTR_H2        = COL_ORANGE
   103 = 0004			ATTR_H3        = COL_GREEN
