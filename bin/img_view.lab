     1 				; ============================================================================
     2 				; VBXE Constants, Register Offsets, and Macros
     3 				; For VBXE Web Browser - Atari XE/XL
     4 				; Assembler: MADS
     5 				; ============================================================================
     6
     7 				; ----------------------------------------------------------------------------
     8 				; VBXE Register Offsets (from base $D640 or $D740)
     9 				; ----------------------------------------------------------------------------
    10
    11 = 0040			VBXE_VCTL      = $40   ; VIDEO_CONTROL (R/W)
    12 = 0040			VBXE_CORE_VER  = $40   ; CORE_VERSION (R) - same offset, read = version
    13
    14 = 0041			VBXE_XDL_ADR0  = $41   ; XDL address low byte (W)
    15 = 0042			VBXE_XDL_ADR1  = $42   ; XDL address mid byte (W) — not used (INY from ADR0), kept for HW reference
    16 = 0043			VBXE_XDL_ADR2  = $43   ; XDL address high byte (W) — not used (INY from ADR0), kept for HW reference
    17
    18 = 0044			VBXE_CSEL      = $44   ; Color Select (index 0-255)
    19 = 0045			VBXE_PSEL      = $45   ; Palette Select (0=playfield, 1=overlay)
    20 = 0046			VBXE_CR        = $46   ; Color Red component
    21 = 0047			VBXE_CG        = $47   ; Color Green component
    22 = 0048			VBXE_CB        = $48   ; Color Blue component
    23
    24 = 0050			VBXE_BL_ADR0   = $50   ; BCB address low
    25 = 0053			VBXE_BLITTER   = $53   ; Write $01=start, Read: non-zero=busy
    26
    27 = 005D			VBXE_MEMAC_B   = $5D   ; MEMAC B control (window $4000-$7FFF)
    28
    29 				; VIDEO_CONTROL bits
    30 = 0001			VC_XDL_ENABLED = $01
    31 = 0002			VC_XCOLOR      = $02
    32
    33 = 0010			FX_CORE_VER    = $10   ; Expected CORE_VERSION for FX core
    34
    35 				; ----------------------------------------------------------------------------
    36 				; XDL Control Word Flags
    37 				; ----------------------------------------------------------------------------
    38 = 0001			XDLC_TMON     = $0001
    39 = 0002			XDLC_GMON     = $0002
    40 = 0004			XDLC_OVOFF    = $0004
    41 = 0010			XDLC_MAPOFF   = $0010
    42 = 0020			XDLC_RPTL     = $0020
    43 = 0040			XDLC_OVADR    = $0040
    44 = 0100			XDLC_CHBASE   = $0100
    45 = 0800			XDLC_OVATT    = $0800
    46 = 8000			XDLC_END      = $8000
    47
    48 				; ----------------------------------------------------------------------------
    49 				; VBXE VRAM Layout
    50 				; ----------------------------------------------------------------------------
    51 = 8000			VRAM_IMG_BASE  = $8000  ; Image viewer: pixel data start (fits 320x240 @8bpp within 128KB VRAM)
    52 = 7A00			ROOM_PATCH_CACHE_MEMB = $7A00 ; MEMAC B address for cached pre-patch pixels (VRAM $17A00)
    53 = 0005			ROOM_PATCH_CACHE_BANK = 5     ; VBXE bank containing ROOM_PATCH_CACHE_MEMB
    54 = 8600			ROOM_PATCH_CACHE_MAX  = $8600 ; 34304 bytes free after 320x200 image within 128KB VRAM
    55 = 0000			VRAM_SCREEN    = $0000  ; Screen: SCR_ROWS*160 bytes (4800 for 30 rows)
    56 = 1300			VRAM_BCB       = $1300  ; BCB blocks (after screen)
    57 = 1380			VRAM_PATTERN   = $1380  ; Fill pattern (2 bytes)
    58 = 1400			VRAM_XDL       = $1400  ; XDL
    59 = 2000			VRAM_FONT      = $2000  ; Font: 256*8 = 2048 bytes
    60 = 0005			PAGE_BUF_BANK  = 5      ; VRAM $14000 >> 14 = 5
    61
    62 				; CPU addresses when MEMAC B bank 0 active ($4000 + VRAM offset)
    63 = 4000			MEMB_BASE      = $4000
    64 = 4000			MEMB_SCREEN    = $4000
    65 = 5300			MEMB_BCB       = $5300
    66 = 5380			MEMB_PATTERN   = $5380
    67 = 5400			MEMB_XDL       = $5400
    68 = 6000			MEMB_FONT      = $6000
    69
    70 				; Screen dimensions
    71 = 0050			SCR_COLS       = 80
    72 = 001D			SCR_ROWS       = 29
    73 = 00A0			SCR_STRIDE     = 160    ; 80 chars + 80 attrs
    74 = 0004			CHBASE_VAL     = 4      ; VRAM_FONT / $800
    75
    76 				; Content area (derived from SCR_ROWS)
    77 = 0002			CONTENT_TOP    = 2
    78 = 001A			CONTENT_BOT    = SCR_ROWS - 3
    79 = 0019			CONTENT_ROWS   = SCR_ROWS - 4
    80 = 0000			URL_ROW        = 0
    81 = 0001			TITLE_ROW      = 1
    82 = 001B			STATUS_ROW     = SCR_ROWS - 2
    83
    84 				; ----------------------------------------------------------------------------
    85 				; Color Palette Indices (overlay palette 1)
    86 				; ----------------------------------------------------------------------------
    87 = 0000			COL_BLACK      = 0
    88 = 0001			COL_WHITE      = 1
    89 = 0002			COL_BLUE       = 2
    90 = 0003			COL_ORANGE     = 3
    91 = 0004			COL_GREEN      = 4
    92 = 0005			COL_RED        = 5
    93 = 0006			COL_GRAY       = 6
    94 = 0007			COL_YELLOW     = 7
    95 = 000C			COL_CYAN       = 12   ; h4 headings
    96 = 000D			COL_PINK       = 13   ; underline
    97 = 000E			COL_LTGRAY     = 14   ; h5/h6 headings, sup/sub
    98 = 000F			COL_LIME       = 15   ; sub
    99
   100 = 0001			ATTR_NORMAL    = COL_WHITE
   101 = 0002			ATTR_LINK      = COL_BLUE     ; basic link color (for UI elements)
   102 = 0020			ATTR_LINK_BASE = $20          ; link attrs: $20+link_num (palette $20-$5F = blue)
   103 = 0003			ATTR_HEADING   = COL_ORANGE
   104 = 0007			ATTR_H1        = COL_YELLOW
   105 = 0003			ATTR_H2        = COL_ORANGE
   106 = 0004			ATTR_H3        = COL_GREEN
