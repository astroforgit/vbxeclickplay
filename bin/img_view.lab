   168 				; ----------------------------------------------------------------------------
   169 33AF			.proc fn_close
   170 33AF A9 71		        lda #FN_DEVID
   171 33B1 8D 00 03		        sta DDEVIC
   172 33B4 AD AE 32		        lda fn_cur_unit
   173 33B7 8D 01 03		        sta DUNIT
   174 33BA A9 43		        lda #FN_CMD_CLOSE
   175 33BC 8D 02 03		        sta DCOMND
   176 33BF A9 00		        lda #SIO_NONE
   177 33C1 8D 03 03		        sta DSTATS
   178 33C4 A9 00		        lda #0
   179 33C6 8D 04 03		        sta DBUFLO
   180 33C9 8D 05 03		        sta DBUFHI
   181 33CC 8D 08 03		        sta DBYTLO
   182 33CF 8D 09 03		        sta DBYTHI
   183 33D2 8D 0A 03		        sta DAUX1
   184 33D5 8D 0B 03		        sta DAUX2
   185 33D8 A9 1E		        lda #FN_TIMEOUT
   186 33DA 8D 06 03		        sta DTIMLO
