   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 2EE4			.proc fn_read
   113 2EE4 A5 A2		        lda zp_fn_bytes_hi
   114 2EE6 D0 06		        bne ?max
   115 2EE8 A5 A1		        lda zp_fn_bytes_lo
   116 2EEA F0 1E		        beq ?nothing
   117 2EEC D0 0F		        bne ?use_lo
   118
   119 2EEE A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 2EF0 85 A3		        sta zp_rx_len
   121 2EF2 8D 08 03		        sta DBYTLO
   122 2EF5 A9 00		        lda #0
   123 2EF7 8D 09 03		        sta DBYTHI
   124 2EFA 4C 10 2F		        jmp ?do
   125
   126 2EFD 85 A3		?use_lo sta zp_rx_len
   127 2EFF 8D 08 03		        sta DBYTLO
   128 2F02 A9 00		        lda #0
   129 2F04 8D 09 03		        sta DBYTHI
   130 2F07 4C 10 2F		        jmp ?do
   131
   132 2F0A			?nothing
   133 2F0A A9 00		        lda #0
   134 2F0C 85 A3		        sta zp_rx_len
   135 2F0E 18			        clc
   136 2F0F 60			        rts
   137
   138 2F10 A9 71		?do     lda #FN_DEVID
   139 2F12 8D 00 03		        sta DDEVIC
   140 2F15 AD 4B 2E		        lda fn_cur_unit
   141 2F18 8D 01 03		        sta DUNIT
   142 2F1B A9 52		        lda #FN_CMD_READ
   143 2F1D 8D 02 03		        sta DCOMND
   144 2F20 A9 40		        lda #SIO_READ
   145 2F22 8D 03 03		        sta DSTATS
   146 2F25 A9 33		        lda #<rx_buffer
   147 2F27 8D 04 03		        sta DBUFLO
   148 2F2A A9 89		        lda #>rx_buffer
   149 2F2C 8D 05 03		        sta DBUFHI
   150 2F2F A9 1E		        lda #FN_TIMEOUT
   151 2F31 8D 06 03		        sta DTIMLO
   152 2F34 AD 08 03		        lda DBYTLO
   153 2F37 8D 0A 03		        sta DAUX1
   154 2F3A AD 09 03		        lda DBYTHI
   155 2F3D 8D 0B 03		        sta DAUX2
   156
   157 2F40 20 59 E4		        jsr SIOV
   158 2F43 AD 03 03		        lda DSTATS
   159 2F46 30 02		        bmi ?err
   160 2F48 18			        clc
   161 2F49 60			        rts
   162 2F4A 38			?err    sec
   163 2F4B 60			        rts
   164 				.endp
