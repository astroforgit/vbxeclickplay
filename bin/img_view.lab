Source: vbxe_const.asm
     1 				; ============================================================================
     2 				; VBXE Constants, Register Offsets, and Macros
     3 				; For VBXE Web Browser - Atari XE/XL
     4 				; Assembler: MADS
     5 				; ============================================================================
     6
     7 				; ----------------------------------------------------------------------------
     8 				; VBXE Register Offsets (from base $D640 or $D740)
     9 				; ----------------------------------------------------------------------------
    10
    11 = 0040			VBXE_VCTL      = $40   ; VIDEO_CONTROL (R/W)
    12 = 0040			VBXE_CORE_VER  = $40   ; CORE_VERSION (R) - same offset, read = version
    13
    14 = 0041			VBXE_XDL_ADR0  = $41   ; XDL address low byte (W)
    15 = 0042			VBXE_XDL_ADR1  = $42   ; XDL address mid byte (W) — not used (INY from ADR0), kept for HW reference
    16 = 0043			VBXE_XDL_ADR2  = $43   ; XDL address high byte (W) — not used (INY from ADR0), kept for HW reference
    17
    18 = 0044			VBXE_CSEL      = $44   ; Color Select (index 0-255)
    19 = 0045			VBXE_PSEL      = $45   ; Palette Select (0=playfield, 1=overlay)
    20 = 0046			VBXE_CR        = $46   ; Color Red component
    21 = 0047			VBXE_CG        = $47   ; Color Green component
    22 = 0048			VBXE_CB        = $48   ; Color Blue component
    23
    24 = 0050			VBXE_BL_ADR0   = $50   ; BCB address low
    25 = 0053			VBXE_BLITTER   = $53   ; Write $01=start, Read: non-zero=busy
    26
    27 = 005D			VBXE_MEMAC_B   = $5D   ; MEMAC B control (window $4000-$7FFF)
    28
    29 				; VIDEO_CONTROL bits
    30 = 0001			VC_XDL_ENABLED = $01
    31 = 0002			VC_XCOLOR      = $02
    32
    33 = 0010			FX_CORE_VER    = $10   ; Expected CORE_VERSION for FX core
    34
    35 				; ----------------------------------------------------------------------------
    36 				; XDL Control Word Flags
    37 				; ----------------------------------------------------------------------------
    38 = 0001			XDLC_TMON     = $0001
    39 = 0002			XDLC_GMON     = $0002
    40 = 0004			XDLC_OVOFF    = $0004
    41 = 0010			XDLC_MAPOFF   = $0010
    42 = 0020			XDLC_RPTL     = $0020
    43 = 0040			XDLC_OVADR    = $0040
    44 = 0100			XDLC_CHBASE   = $0100
    45 = 0800			XDLC_OVATT    = $0800
    46 = 8000			XDLC_END      = $8000
    47
    48 				; ----------------------------------------------------------------------------
    49 				; VBXE VRAM Layout
    50 				; ----------------------------------------------------------------------------
    51 = 8000			VRAM_IMG_BASE  = $8000  ; Image viewer: pixel data start (fits 320x200 @8bpp within 128KB VRAM)
    52 = 7A00			ROOM_POPUP_CACHE_MEMB = $7A00     ; MEMAC B address for popup save-under scratch (VRAM $17A00)
    53 = 0005			ROOM_POPUP_CACHE_BANK = 5         ; VBXE bank containing ROOM_POPUP_CACHE_MEMB
    54 = 3C88			ROOM_POPUP_CACHE_MAX  = $3C88     ; 15496 bytes reserved for popup save-under (298x52 max)
    55 = 7688			ROOM_SELECTION_CACHE_MEMB = $7688 ; MEMAC B address for cached selection patches (VRAM $1B688)
    56 = 0006			ROOM_SELECTION_CACHE_BANK = 6     ; VBXE bank containing ROOM_SELECTION_CACHE_MEMB
    57 = 0F78			ROOM_SELECTION_CACHE_MAX  = $0F78 ; 3960 bytes reserved for selection-patch cache after popup scratch
    58 = 4600			ROOM_PATCH_CACHE_MEMB = $4600     ; MEMAC B address for cached pre-patch pixels (VRAM $1C600)
    59 = 0007			ROOM_PATCH_CACHE_BANK = 7         ; VBXE bank containing ROOM_PATCH_CACHE_MEMB
    60 = 3A00			ROOM_PATCH_CACHE_MAX  = $3A00     ; 14848 bytes reserved for original-background undo cache
    61 = 0000			VRAM_SCREEN    = $0000  ; Screen: SCR_ROWS*160 bytes (4800 for 30 rows)
    62 = 1300			VRAM_BCB       = $1300  ; BCB blocks (after screen)
    63 = 1380			VRAM_PATTERN   = $1380  ; Fill pattern (2 bytes)
    64 = 1400			VRAM_XDL       = $1400  ; XDL
    65 = 2000			VRAM_FONT      = $2000  ; Font: 256*8 = 2048 bytes
    66 = 0005			PAGE_BUF_BANK  = 5      ; VRAM $14000 >> 14 = 5
    67
    68 				; CPU addresses when MEMAC B bank 0 active ($4000 + VRAM offset)
    69 = 4000			MEMB_BASE      = $4000
    70 = 4000			MEMB_SCREEN    = $4000
    71 = 5300			MEMB_BCB       = $5300
    72 = 5380			MEMB_PATTERN   = $5380
    73 = 5400			MEMB_XDL       = $5400
    74 = 6000			MEMB_FONT      = $6000
    75
    76 				; Screen dimensions
    77 = 0050			SCR_COLS       = 80
    78 = 001D			SCR_ROWS       = 29
    79 = 00A0			SCR_STRIDE     = 160    ; 80 chars + 80 attrs
    80 = 0004			CHBASE_VAL     = 4      ; VRAM_FONT / $800
    81
    82 				; Content area (derived from SCR_ROWS)
    83 = 0002			CONTENT_TOP    = 2
    84 = 001A			CONTENT_BOT    = SCR_ROWS - 3
    85 = 0019			CONTENT_ROWS   = SCR_ROWS - 4
    86 = 0000			URL_ROW        = 0
    87 = 0001			TITLE_ROW      = 1
    88 = 001B			STATUS_ROW     = SCR_ROWS - 2
    89
