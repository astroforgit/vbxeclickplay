    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 2F34			.proc fn_open
    26 2F34 A9 71		        lda #FN_DEVID
    27 2F36 8D 00 03		        sta DDEVIC
    28 2F39 AD 33 2F		        lda fn_cur_unit
