    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 2E90			.proc fn_status
    65 2E90 A9 71		        lda #FN_DEVID
    66 2E92 8D 00 03		        sta DDEVIC
    67 2E95 AD 4B 2E		        lda fn_cur_unit
    68 2E98 8D 01 03		        sta DUNIT
    69 2E9B A9 53		        lda #FN_CMD_STATUS
    70 2E9D 8D 02 03		        sta DCOMND
    71 2EA0 A9 40		        lda #SIO_READ
    72 2EA2 8D 03 03		        sta DSTATS
    73 2EA5 A9 EA		        lda #<DVSTAT
    74 2EA7 8D 04 03		        sta DBUFLO
    75 2EAA A9 02		        lda #>DVSTAT
    76 2EAC 8D 05 03		        sta DBUFHI
    77 2EAF A9 1E		        lda #FN_TIMEOUT
    78 2EB1 8D 06 03		        sta DTIMLO
    79 2EB4 A9 04		        lda #4
    80 2EB6 8D 08 03		        sta DBYTLO
    81 2EB9 A9 00		        lda #0
    82 2EBB 8D 09 03		        sta DBYTHI
    83 2EBE 8D 0A 03		        sta DAUX1
    84 2EC1 8D 0B 03		        sta DAUX2
    85
    86 2EC4 20 59 E4		        jsr SIOV
    87 2EC7 AD 03 03		        lda DSTATS
    88 2ECA 30 16		        bmi ?err
    89
    90 2ECC AD EA 02		        lda DVSTAT
    91 2ECF 85 A1		        sta zp_fn_bytes_lo
    92 2ED1 AD EB 02		        lda DVSTAT+1
    93 2ED4 85 A2		        sta zp_fn_bytes_hi
    94 2ED6 AD EC 02		        lda DVSTAT+2
    95 2ED9 85 9F		        sta zp_fn_connected
    96 2EDB AD ED 02		        lda DVSTAT+3
    97 2EDE 85 A0		        sta zp_fn_error
    98
    99 2EE0 18			        clc
   100 2EE1 60			        rts
   101 2EE2 38			?err    sec
   102 2EE3 60			        rts
   103 				.endp
