    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 34D3			.proc fn_open
    26 34D3 A9 71		        lda #FN_DEVID
    27 34D5 8D 00 03		        sta DDEVIC
    28 34D8 AD D2 34		        lda fn_cur_unit
    29 34DB 8D 01 03		        sta DUNIT
    30 34DE A9 4F		        lda #FN_CMD_OPEN
    31 34E0 8D 02 03		        sta DCOMND
    32 34E3 A9 80		        lda #SIO_WRITE
    33 34E5 8D 03 03		        sta DSTATS
    34 34E8 A9 87		        lda #<url_buffer
    35 34EA 8D 04 03		        sta DBUFLO
    36 34ED A9 88		        lda #>url_buffer
    37 34EF 8D 05 03		        sta DBUFHI
    38 34F2 A9 1E		        lda #FN_TIMEOUT
    39 34F4 8D 06 03		        sta DTIMLO
    40 34F7 A9 00		        lda #<URL_BUF_SIZE
    41 34F9 8D 08 03		        sta DBYTLO
    42 34FC A9 01		        lda #>URL_BUF_SIZE
    43 34FE 8D 09 03		        sta DBYTHI
    44 3501 A9 04		        lda #FN_OPEN_READ
    45 3503 8D 0A 03		        sta DAUX1
    46 3506 A9 00		        lda #FN_TRANS_NONE
    47 3508 8D 0B 03		        sta DAUX2
    48
    49 350B 20 59 E4		        jsr SIOV
    50 350E AD 03 03		        lda DSTATS
    51 3511 30 02		        bmi ?err
    52 3513 18			        clc
    53 3514 60			        rts
    54 3515 38			?err    sec
    55 3516 60			        rts
    56 				.endp
    57
    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 3517			.proc fn_status
    65 3517 A9 71		        lda #FN_DEVID
    66 3519 8D 00 03		        sta DDEVIC
    67 351C AD D2 34		        lda fn_cur_unit
    68 351F 8D 01 03		        sta DUNIT
    69 3522 A9 53		        lda #FN_CMD_STATUS
    70 3524 8D 02 03		        sta DCOMND
    71 3527 A9 40		        lda #SIO_READ
    72 3529 8D 03 03		        sta DSTATS
    73 352C A9 EA		        lda #<DVSTAT
    74 352E 8D 04 03		        sta DBUFLO
    75 3531 A9 02		        lda #>DVSTAT
    76 3533 8D 05 03		        sta DBUFHI
    77 3536 A9 1E		        lda #FN_TIMEOUT
    78 3538 8D 06 03		        sta DTIMLO
    79 353B A9 04		        lda #4
    80 353D 8D 08 03		        sta DBYTLO
    81 3540 A9 00		        lda #0
    82 3542 8D 09 03		        sta DBYTHI
    83 3545 8D 0A 03		        sta DAUX1
    84 3548 8D 0B 03		        sta DAUX2
    85
    86 354B 20 59 E4		        jsr SIOV
    87 354E AD 03 03		        lda DSTATS
    88 3551 30 16		        bmi ?err
    89
    90 3553 AD EA 02		        lda DVSTAT
    91 3556 85 A1		        sta zp_fn_bytes_lo
    92 3558 AD EB 02		        lda DVSTAT+1
    93 355B 85 A2		        sta zp_fn_bytes_hi
    94 355D AD EC 02		        lda DVSTAT+2
    95 3560 85 9F		        sta zp_fn_connected
    96 3562 AD ED 02		        lda DVSTAT+3
    97 3565 85 A0		        sta zp_fn_error
    98
    99 3567 18			        clc
   100 3568 60			        rts
   101 3569 38			?err    sec
   102 356A 60			        rts
   103 				.endp
   104
   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 356B			.proc fn_read
   113 356B A5 A2		        lda zp_fn_bytes_hi
   114 356D D0 06		        bne ?max
   115 356F A5 A1		        lda zp_fn_bytes_lo
   116 3571 F0 1E		        beq ?nothing
   117 3573 D0 0F		        bne ?use_lo
   118
   119 3575 A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 3577 85 A3		        sta zp_rx_len
   121 3579 8D 08 03		        sta DBYTLO
   122 357C A9 00		        lda #0
   123 357E 8D 09 03		        sta DBYTHI
   124 3581 4C 97 35		        jmp ?do
   125
   126 3584 85 A3		?use_lo sta zp_rx_len
   127 3586 8D 08 03		        sta DBYTLO
   128 3589 A9 00		        lda #0
   129 358B 8D 09 03		        sta DBYTHI
   130 358E 4C 97 35		        jmp ?do
   131
   132 3591			?nothing
   133 3591 A9 00		        lda #0
   134 3593 85 A3		        sta zp_rx_len
   135 3595 18			        clc
   136 3596 60			        rts
   137
   138 3597 A9 71		?do     lda #FN_DEVID
   139 3599 8D 00 03		        sta DDEVIC
   140 359C AD D2 34		        lda fn_cur_unit
   141 359F 8D 01 03		        sta DUNIT
   142 35A2 A9 52		        lda #FN_CMD_READ
   143 35A4 8D 02 03		        sta DCOMND
   144 35A7 A9 40		        lda #SIO_READ
   145 35A9 8D 03 03		        sta DSTATS
   146 35AC A9 87		        lda #<rx_buffer
   147 35AE 8D 04 03		        sta DBUFLO
   148 35B1 A9 89		        lda #>rx_buffer
   149 35B3 8D 05 03		        sta DBUFHI
   150 35B6 A9 1E		        lda #FN_TIMEOUT
   151 35B8 8D 06 03		        sta DTIMLO
   152 35BB AD 08 03		        lda DBYTLO
   153 35BE 8D 0A 03		        sta DAUX1
   154 35C1 AD 09 03		        lda DBYTHI
   155 35C4 8D 0B 03		        sta DAUX2
   156
   157 35C7 20 59 E4		        jsr SIOV
   158 35CA AD 03 03		        lda DSTATS
   159 35CD 30 02		        bmi ?err
   160 35CF 18			        clc
   161 35D0 60			        rts
   162 35D1 38			?err    sec
   163 35D2 60			        rts
   164 				.endp
   165
   166 				; ----------------------------------------------------------------------------
   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 35D3			.proc fn_close
   170 35D3 A9 71		        lda #FN_DEVID
   171 35D5 8D 00 03		        sta DDEVIC
   172 35D8 AD D2 34		        lda fn_cur_unit
   173 35DB 8D 01 03		        sta DUNIT
   174 35DE A9 43		        lda #FN_CMD_CLOSE
   175 35E0 8D 02 03		        sta DCOMND
   176 35E3 A9 00		        lda #SIO_NONE
   177 35E5 8D 03 03		        sta DSTATS
   178 35E8 A9 00		        lda #0
   179 35EA 8D 04 03		        sta DBUFLO
   180 35ED 8D 05 03		        sta DBUFHI
   181 35F0 8D 08 03		        sta DBYTLO
   182 35F3 8D 09 03		        sta DBYTHI
   183 35F6 8D 0A 03		        sta DAUX1
   184 35F9 8D 0B 03		        sta DAUX2
   185 35FC A9 1E		        lda #FN_TIMEOUT
   186 35FE 8D 06 03		        sta DTIMLO
   187
   188 3601 4C 59 E4		        jmp SIOV
   189 				.endp
