     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 2B8C 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
