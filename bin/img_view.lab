   205
   206 = 00A4			zp_cur_link    = $A4
   207 = 00A5			zp_scroll_pos  = $A5   ; 2 bytes
   208 				; $A7-$A8 free (removed: zp_page_lines — write-only)
   209 = 00A9			zp_hist_ptr    = $A9   ; 1 byte - history stack index (0-7)
   210 				; $AA free (removed: zp_fn_got_data — never referenced)
   211 = 00AB			zp_img_ptr     = $AB   ; 2 bytes - image write pointer (MEMAC B window)
   212 = 00AD			zp_memb_shadow = $AD   ; MEMAC B shadow for NMI-safe restore
   213 = 00AE			zp_tirq_saved  = $AE   ; Timer IRQ: saved shadow value
   214 = 00AF			zp_vbi_saved   = $AF   ; VBI: saved shadow value
   215
   216 				; Page buffer pointers ($B8-$BB, after mouse $B0-$B7)
   217 = 00B8			zp_pb_wr_ptr   = $B8   ; 2B write pointer (MEMAC B window $4000-$7FFF)
   218 = 00BA			zp_pb_rd_ptr   = $BA   ; 2B read pointer
   219
   220 				; TAB navigation ($BC)
   221 = 00BC			zp_tab_link    = $BC   ; currently selected link via TAB ($FF = none)
