    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 328B			.proc fn_open
    26 328B A9 71		        lda #FN_DEVID
    27 328D 8D 00 03		        sta DDEVIC
    28 3290 AD 8A 32		        lda fn_cur_unit
    29 3293 8D 01 03		        sta DUNIT
