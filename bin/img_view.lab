   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 3D55			.proc fn_read
   113 3D55 A5 A2		        lda zp_fn_bytes_hi
   114 3D57 D0 06		        bne ?max
   115 3D59 A5 A1		        lda zp_fn_bytes_lo
   116 3D5B F0 1E		        beq ?nothing
   117 3D5D D0 0F		        bne ?use_lo
   118
   119 3D5F A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 3D61 85 A3		        sta zp_rx_len
   121 3D63 8D 08 03		        sta DBYTLO
   122 3D66 A9 00		        lda #0
   123 3D68 8D 09 03		        sta DBYTHI
   124 3D6B 4C 81 3D		        jmp ?do
   125
   126 3D6E 85 A3		?use_lo sta zp_rx_len
   127 3D70 8D 08 03		        sta DBYTLO
   128 3D73 A9 00		        lda #0
   129 3D75 8D 09 03		        sta DBYTHI
   130 3D78 4C 81 3D		        jmp ?do
   131
   132 3D7B			?nothing
   133 3D7B A9 00		        lda #0
   134 3D7D 85 A3		        sta zp_rx_len
   135 3D7F 18			        clc
   136 3D80 60			        rts
   137
   138 3D81 A9 71		?do     lda #FN_DEVID
   139 3D83 8D 00 03		        sta DDEVIC
   140 3D86 AD BC 3C		        lda fn_cur_unit
   141 3D89 8D 01 03		        sta DUNIT
   142 3D8C A9 52		        lda #FN_CMD_READ
   143 3D8E 8D 02 03		        sta DCOMND
   144 3D91 A9 40		        lda #SIO_READ
   145 3D93 8D 03 03		        sta DSTATS
   146 3D96 A9 F5		        lda #<rx_buffer
   147 3D98 8D 04 03		        sta DBUFLO
   148 3D9B A9 89		        lda #>rx_buffer
   149 3D9D 8D 05 03		        sta DBUFHI
   150 3DA0 A9 1E		        lda #FN_TIMEOUT
   151 3DA2 8D 06 03		        sta DTIMLO
   152 3DA5 AD 08 03		        lda DBYTLO
   153 3DA8 8D 0A 03		        sta DAUX1
   154 3DAB AD 09 03		        lda DBYTHI
   155 3DAE 8D 0B 03		        sta DAUX2
   156
   157 3DB1 20 59 E4		        jsr SIOV
   158 3DB4 AD 03 03		        lda DSTATS
   159 3DB7 30 02		        bmi ?err
   160 3DB9 18			        clc
   161 3DBA 60			        rts
   162 3DBB 38			?err    sec
   163 3DBC 60			        rts
   164 				.endp
   165
   166 				; ----------------------------------------------------------------------------
   167 				; fn_close - Close FujiNet connection
   168 				; ----------------------------------------------------------------------------
   169 3DBD			.proc fn_close
   170 3DBD A9 71		        lda #FN_DEVID
   171 3DBF 8D 00 03		        sta DDEVIC
   172 3DC2 AD BC 3C		        lda fn_cur_unit
   173 3DC5 8D 01 03		        sta DUNIT
   174 3DC8 A9 43		        lda #FN_CMD_CLOSE
   175 3DCA 8D 02 03		        sta DCOMND
   176 3DCD A9 00		        lda #SIO_NONE
   177 3DCF 8D 03 03		        sta DSTATS
   178 3DD2 A9 00		        lda #0
   179 3DD4 8D 04 03		        sta DBUFLO
   180 3DD7 8D 05 03		        sta DBUFHI
   181 3DDA 8D 08 03		        sta DBYTLO
   182 3DDD 8D 09 03		        sta DBYTHI
   183 3DE0 8D 0A 03		        sta DAUX1
   184 3DE3 8D 0B 03		        sta DAUX2
   185 3DE6 A9 1E		        lda #FN_TIMEOUT
   186 3DE8 8D 06 03		        sta DTIMLO
   187
   188 3DEB 4C 59 E4		        jmp SIOV
   189 				.endp
