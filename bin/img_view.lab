     1 				; ============================================================================
     2 				; FujiNet N: Device SIO Layer
     3 				; ============================================================================
     4
     5 = 0071			FN_DEVID       = $71
     6 = 0001			FN_UNIT        = 1
     7 27A4 01			fn_cur_unit    dta FN_UNIT     ; current N: unit (1=page, 2=image)
     8 = 004F			FN_CMD_OPEN    = 'O'
     9 = 0043			FN_CMD_CLOSE   = 'C'
    10 = 0052			FN_CMD_READ    = 'R'
    11 = 0053			FN_CMD_STATUS  = 'S'
    12 = 0040			SIO_READ       = $40
    13 = 0080			SIO_WRITE      = $80
    14 = 0000			SIO_NONE       = $00
    15 = 0004			FN_OPEN_READ   = 4
    16 = 0000			FN_TRANS_NONE  = 0
    17 = 001E			FN_TIMEOUT     = 30
    18 = 0100			URL_BUF_SIZE   = 256
    19 = 0100			RX_BUF_SIZE    = 256
    20
    21 				; ----------------------------------------------------------------------------
    22 				; fn_open - Open FujiNet connection (url_buffer -> OPEN)
    23 				; Output: C=0 ok, C=1 error
    24 				; ----------------------------------------------------------------------------
    25 27A5			.proc fn_open
    26 27A5 A9 71		        lda #FN_DEVID
    27 27A7 8D 00 03		        sta DDEVIC
    28 27AA AD A4 27		        lda fn_cur_unit
    29 27AD 8D 01 03		        sta DUNIT
    30 27B0 A9 4F		        lda #FN_CMD_OPEN
    31 27B2 8D 02 03		        sta DCOMND
    32 27B5 A9 80		        lda #SIO_WRITE
    33 27B7 8D 03 03		        sta DSTATS
    34 27BA A9 18		        lda #<url_buffer
    35 27BC 8D 04 03		        sta DBUFLO
    36 27BF A9 88		        lda #>url_buffer
    37 27C1 8D 05 03		        sta DBUFHI
    38 27C4 A9 1E		        lda #FN_TIMEOUT
    39 27C6 8D 06 03		        sta DTIMLO
    40 27C9 A9 00		        lda #<URL_BUF_SIZE
    41 27CB 8D 08 03		        sta DBYTLO
    42 27CE A9 01		        lda #>URL_BUF_SIZE
    43 27D0 8D 09 03		        sta DBYTHI
    44 27D3 A9 04		        lda #FN_OPEN_READ
    45 27D5 8D 0A 03		        sta DAUX1
    46 27D8 A9 00		        lda #FN_TRANS_NONE
    47 27DA 8D 0B 03		        sta DAUX2
    48
    49 27DD 20 59 E4		        jsr SIOV
    50 27E0 AD 03 03		        lda DSTATS
    51 27E3 30 02		        bmi ?err
    52 27E5 18			        clc
    53 27E6 60			        rts
    54 27E7 38			?err    sec
    55 27E8 60			        rts
    56 				.endp
    57
    58 				; ----------------------------------------------------------------------------
    59 				; fn_status - Get FujiNet status (bytes waiting, connected, error)
    60 				; Reads 4-byte DVSTAT: [0]=bytes_lo, [1]=bytes_hi, [2]=connected, [3]=error
    61 				; Error codes: 0=ok, 136($88)=EOF/closed, other=fatal
    62 				; Output: zp_fn_bytes_lo/hi, zp_fn_connected, zp_fn_error, C=0/1
    63 				; ----------------------------------------------------------------------------
    64 27E9			.proc fn_status
    65 27E9 A9 71		        lda #FN_DEVID
    66 27EB 8D 00 03		        sta DDEVIC
    67 27EE AD A4 27		        lda fn_cur_unit
    68 27F1 8D 01 03		        sta DUNIT
    69 27F4 A9 53		        lda #FN_CMD_STATUS
    70 27F6 8D 02 03		        sta DCOMND
    71 27F9 A9 40		        lda #SIO_READ
    72 27FB 8D 03 03		        sta DSTATS
    73 27FE A9 EA		        lda #<DVSTAT
    74 2800 8D 04 03		        sta DBUFLO
    75 2803 A9 02		        lda #>DVSTAT
    76 2805 8D 05 03		        sta DBUFHI
    77 2808 A9 1E		        lda #FN_TIMEOUT
    78 280A 8D 06 03		        sta DTIMLO
    79 280D A9 04		        lda #4
    80 280F 8D 08 03		        sta DBYTLO
    81 2812 A9 00		        lda #0
    82 2814 8D 09 03		        sta DBYTHI
    83 2817 8D 0A 03		        sta DAUX1
    84 281A 8D 0B 03		        sta DAUX2
    85
    86 281D 20 59 E4		        jsr SIOV
    87 2820 AD 03 03		        lda DSTATS
    88 2823 30 16		        bmi ?err
    89
    90 2825 AD EA 02		        lda DVSTAT
    91 2828 85 A1		        sta zp_fn_bytes_lo
    92 282A AD EB 02		        lda DVSTAT+1
    93 282D 85 A2		        sta zp_fn_bytes_hi
    94 282F AD EC 02		        lda DVSTAT+2
    95 2832 85 9F		        sta zp_fn_connected
    96 2834 AD ED 02		        lda DVSTAT+3
    97 2837 85 A0		        sta zp_fn_error
    98
    99 2839 18			        clc
   100 283A 60			        rts
   101 283B 38			?err    sec
   102 283C 60			        rts
   103 				.endp
   104
   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 283D			.proc fn_read
   113 283D A5 A2		        lda zp_fn_bytes_hi
   114 283F D0 06		        bne ?max
   115 2841 A5 A1		        lda zp_fn_bytes_lo
