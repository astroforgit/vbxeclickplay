   174 33B2 A9 43		        lda #FN_CMD_CLOSE
   175 33B4 8D 02 03		        sta DCOMND
   176 33B7 A9 00		        lda #SIO_NONE
   177 33B9 8D 03 03		        sta DSTATS
   178 33BC A9 00		        lda #0
   179 33BE 8D 04 03		        sta DBUFLO
   180 33C1 8D 05 03		        sta DBUFHI
   181 33C4 8D 08 03		        sta DBYTLO
   182 33C7 8D 09 03		        sta DBYTHI
   183 33CA 8D 0A 03		        sta DAUX1
