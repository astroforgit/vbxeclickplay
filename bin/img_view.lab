   174 303F A9 43		        lda #FN_CMD_CLOSE
   175 3041 8D 02 03		        sta DCOMND
   176 3044 A9 00		        lda #SIO_NONE
   177 3046 8D 03 03		        sta DSTATS
   178 3049 A9 00		        lda #0
