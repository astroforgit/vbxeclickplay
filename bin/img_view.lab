   220 = 00AF			zp_vbi_saved   = $AF   ; VBI: saved shadow value
   221
   222 				; Page buffer pointers ($B8-$BB, after mouse $B0-$B7)
   223 = 00B8			zp_pb_wr_ptr   = $B8   ; 2B write pointer (MEMAC B window $4000-$7FFF)
   224 = 00BA			zp_pb_rd_ptr   = $BA   ; 2B read pointer
