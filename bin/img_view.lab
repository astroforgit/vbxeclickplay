   119 = 0012			RTCLOK     = $0012
   120 = 022F			SDMCTL     = $022F
   121 = 0279			STICK1     = $0279
   122 = 02F4			CHBAS      = $02F4
   123 = 02FC			CH         = $02FC
   124 = D400			DMACTL     = $D400
