    38 = 0001			XDLC_TMON     = $0001
    39 = 0002			XDLC_GMON     = $0002
    40 = 0004			XDLC_OVOFF    = $0004
    41 = 0010			XDLC_MAPOFF   = $0010
    42 = 0020			XDLC_RPTL     = $0020
    43 = 0040			XDLC_OVADR    = $0040
