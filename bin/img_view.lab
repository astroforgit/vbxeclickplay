   223 				; ----------------------------------------------------------------------------
   224 				; Macros
   225 				; ----------------------------------------------------------------------------
   226
   227 				; MEMAC B macros with shadow variable for interrupt-safe restore.
   228 				; IMPORTANT: Code using these macros MUST be below $4000!
   229 				; When MEMAC B is active, $4000-$7FFF reads VRAM, not RAM.
   230 				; Interrupt handlers use stubs at page 6 to disable/restore MEMAC B.
   231 				memb_on .macro
   232 				        lda #$80+:1
   233 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   234 				        ldy #VBXE_MEMAC_B
   235 				        sta (zp_vbxe_base),y
   236 				        .endm
   237
   238 				memb_off .macro
   239 				        lda #0
   240 				        sta zp_memb_shadow     ; shadow FIRST (NMI-safe ordering)
   241 				        ldy #VBXE_MEMAC_B
   242 				        sta (zp_vbxe_base),y
   243 				        .endm
   244
   245 				; Show message on status bar: :1=color, :2=message address
   246 				; Expands to subroutine call (9 bytes) instead of inline (31 bytes)
   247 				status_msg .macro
   248 				        ldy #:1
   249 				        lda #<:2
   250 				        ldx #>:2
   251 				        jsr status_msg_sub
   252 				        .endm
   253
   254 				; Wait N frames (RTCLOK-based delay): :1=frame count
   255 				; Expands to subroutine call (5 bytes) instead of inline (13 bytes)
   256 				wait_frames .macro
   257 				        ldx #:1
   258 				        jsr wait_frames_sub
   259 				        .endm
   260
   261 				blit_start .macro
   262 				        ldy #VBXE_BL_ADR0
   263 				        lda #<:1
   264 				        sta (zp_vbxe_base),y
   265 				        iny
   266 				        lda #>:1
   267 				        sta (zp_vbxe_base),y
   268 				        iny
   269 				        lda #0
   270 				        sta (zp_vbxe_base),y
   271 				        iny
   272 				        lda #1
   273 				        sta (zp_vbxe_base),y
   274 				        .endm
   275
   276 				blit_wait .macro
   277 				        ldy #VBXE_BLITTER
   278 				?bw     lda (zp_vbxe_base),y
   279 				        bne ?bw
   280 				        .endm
