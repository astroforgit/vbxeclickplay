   114 				; Atari System Equates
   115 				; ----------------------------------------------------------------------------
   116 = 0012			RTCLOK     = $0012
   117 = 022F			SDMCTL     = $022F
   118 = 0279			STICK1     = $0279
   119 = 02F4			CHBAS      = $02F4
   120 = 02FC			CH         = $02FC
   121 = D400			DMACTL     = $D400
