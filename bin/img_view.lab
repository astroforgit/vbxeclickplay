   105 				; ----------------------------------------------------------------------------
   106 				; fn_read - Read data from FujiNet into rx_buffer
   107 				; Uses zp_fn_bytes_lo/hi from fn_status, caps at 255 (8-bit zp_rx_len)
   108 				; Reading 256 would set zp_rx_len=0 (overflow!) — always read max 255
   109 				; DAUX1/DAUX2 must match DBYTLO/DBYTHI (FujiNet requirement)
   110 				; Output: zp_rx_len = bytes read, C=0/1
   111 				; ----------------------------------------------------------------------------
   112 3323			.proc fn_read
   113 3323 A5 A2		        lda zp_fn_bytes_hi
   114 3325 D0 06		        bne ?max
   115 3327 A5 A1		        lda zp_fn_bytes_lo
   116 3329 F0 1E		        beq ?nothing
   117 332B D0 0F		        bne ?use_lo
   118
   119 332D A9 FF		?max    lda #255                       ; Max 255 bytes (fits in 8-bit rx_len)
   120 332F 85 A3		        sta zp_rx_len
   121 3331 8D 08 03		        sta DBYTLO
   122 3334 A9 00		        lda #0
   123 3336 8D 09 03		        sta DBYTHI
   124 3339 4C 4F 33		        jmp ?do
   125
   126 333C 85 A3		?use_lo sta zp_rx_len
   127 333E 8D 08 03		        sta DBYTLO
   128 3341 A9 00		        lda #0
   129 3343 8D 09 03		        sta DBYTHI
   130 3346 4C 4F 33		        jmp ?do
   131
   132 3349			?nothing
   133 3349 A9 00		        lda #0
   134 334B 85 A3		        sta zp_rx_len
   135 334D 18			        clc
   136 334E 60			        rts
   137
   138 334F A9 71		?do     lda #FN_DEVID
   139 3351 8D 00 03		        sta DDEVIC
   140 3354 AD 8A 32		        lda fn_cur_unit
   141 3357 8D 01 03		        sta DUNIT
   142 335A A9 52		        lda #FN_CMD_READ
   143 335C 8D 02 03		        sta DCOMND
   144 335F A9 40		        lda #SIO_READ
   145 3361 8D 03 03		        sta DSTATS
   146 3364 A9 60		        lda #<rx_buffer
   147 3366 8D 04 03		        sta DBUFLO
   148 3369 A9 89		        lda #>rx_buffer
   149 336B 8D 05 03		        sta DBUFHI
   150 336E A9 1E		        lda #FN_TIMEOUT
   151 3370 8D 06 03		        sta DTIMLO
   152 3373 AD 08 03		        lda DBYTLO
   153 3376 8D 0A 03		        sta DAUX1
   154 3379 AD 09 03		        lda DBYTHI
   155 337C 8D 0B 03		        sta DAUX2
   156
   157 337F 20 59 E4		        jsr SIOV
   158 3382 AD 03 03		        lda DSTATS
   159 3385 30 02		        bmi ?err
   160 3387 18			        clc
   161 3388 60			        rts
   162 3389 38			?err    sec
   163 338A 60			        rts
   164 				.endp
