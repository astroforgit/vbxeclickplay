  0BB7  6911                ADC     #LOW OUTBAS     ;CARRY CLEAR FROM SHIFT
  0BB9  8D0403              STA     DBUFLO
  0BBC  A900                LDA     #0
  0BBE  8D0903              STA     DBYTHI
  0BC1  690D                ADC     #HIGH OUTBAS
