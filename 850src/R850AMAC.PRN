  0DBE  = 0001      RSCHAR  DS      1       ;RS232 XMIT CHARACTER (UNTRANSLATED)
  0DBF              DUMMY                   ;END OF BUFFERS POINTER
        = 06BF      RHLONG  =       DUMMY-ORIGIN    ;TOTAL LENGTH OF HANDLER
                    
                    
