                    ;       ;  VECTOR TABLE
                    ;
                    ;HANDLER ENTRY POINTS ARE CALLED OUT IN THE FOLLOWING VECTOR
                    ;TABLE. THESE ARE THE ADDRESSES MINUS ONE.
                    ;
                    ;RS-232 HANDLER (RELOCATING VERSION !!)
                    ;
                    ;RS-232 HANDLER CODE (COLLEEN RESIDENT)
                    ;
                    ;
        = 0700      ORIGIN  =       $700    ; PROGRAM ORIGIN FOR ASSEMBLER
        = 0020      RBFSIZ  =       32
        = 0053      RSTAT   =       'S'     ;DCB STATUS COMMAND
        = 0057      WRITE   =       'W'     ;DCB WRITE COMMAND
        = 0041      CTLCOM  =       'A'     ;DCB CONTROL COMMAND
        = 0058      STRCOM  =       'X'     ;DCB STREAM COMMAND
        = 0042      CNFCOM  =       'B'     ;DCB CONFIGURE COMMAND
        = 0028      STRCMD  =       $28     ;IOCB STREAM COMMAND
        = 0026      TRNCMD  =       $26     ;IOCB TRANSLATE COMMAND
        = 0024      CNFCMD  =       $24     ;IOCB CONFIGURE COMMAND
        = 0022      CTLCMD  =       $22     ;IOCB CONTROL COMMAND
        = 0020      FRCCMD  =       $20     ;IOCB FORCE BLOCK COMMAND
        = 0050      RSADRS  =       $50     ;RS-232 DEVICE ADDRESS
        = 0096      PRTOPN  =       150     ;PORT ALREADY OPEN ERROR
        = 0097      NOSTER  =       151     ;PORT NOT OPEN FOR STREAM ERROR
        = 0098      BADBUF  =       152     ;BAD USER-SUPPLIED BUFFERS
        = 0099      STACTV  =       153     ;ANOTHER STREAM IS ALREADY ACTIVE
        = 009A      NOSTAC  =       154     ;NO STREAM IS ACTIVE (THUS, NO INPUT ALLOWED)
                    
                            LIST    I
                    
                    
                    ;       INCLUDE D:R850DEF
                    
  0600  = 0700              ORG     ORIGIN  ;DEVELOPMENT ORIGIN
                    
  0700  20430C      RHOPEN  JSR     RDVTST  ;TEST FOR VALID DEVICE NUMBER
                    
  0703  BD9C0D              LDA     IOCTRL-1,X
  0706  1003 ^070B          BPL     RNTOPN  ;TEST FOR PORT ALREADY OPEN
  0708  A096                LDY     #PRTOPN ;ERROR, PORT ALREADY OPENED
  070A  60                  RTS
                    
  070B  A52A        RNTOPN  LDA     ICAX1Z
  070D  A8                  TAY
  070E  290C                AND     #12
  0710  D003 ^0715          BNE     ROKOPN
  0712  A084                LDY     #132    ;ERROR, NO PERMISSIONS GRANTED ON OPEN
  0714  60                  RTS
  0715  98          ROKOPN  TYA
  0716  0980                ORA     #$80
  0718  9D9C0D              STA     IOCTRL-1,X      ;SET-UP PERMISSION BYTE
  071B  A900                LDA     #0
  071D  9D940D              STA     PUTCTR-1,X      ;INITIALIZE PUT-COUNTER
                  ATARI CAMAC Assembler Ver  1.0A  Page  15
                                                       D1:R850AMAC.       
                                                    

  0720  9D980D              STA     RERROR-1,X      ;CLEAR ERROR FLAGS
  0723  A001                LDY     #SUCCES
  0725  60                  RTS
                    
  0726  20430C      RHCLOS  JSR     RDVTST  ;TEST DEVICE NUMBER FOR VALIDITY
                    
  0729  ECBD0D              CPX     ACTSTR
  072C  F00C ^073A          BEQ     CLSTRM  ;TEST FOR ACTIVE STREAM, BRANCH IF SO
                    
  072E  BD940D              LDA     PUTCTR-1,X
  0731  F02C ^075F          BEQ     MTPBUF  ;TEST FOR BUFFER EMPTY, BRANCH IF SO
                    
  0733  20B40B              JSR     PREPUT  ;PREPARE TO DO A PUT-BLOCK
  0736  A080                LDY     #$80
  0738  D02A ^0764          BNE     CLSPUT  ;JOIN AND SEND DCB (BRANCH IS A JUMP)
                    
  073A  ADBC0D      CLSTRM  LDA     ALLDUN
  073D  F0FB ^073A          BEQ     CLSTRM  ;WAIT FOR BUFFER TO DRAIN
  073F  78                  SEI
  0740  ADBA0D              LDA     RMAINV
  0743  8D1602              STA     VIMIRQ
  0746  ADBB0D              LDA     RMAINV+1
  0749  8D1702              STA     VIMIRQ+1        ;RESTORE MAIN SYSTEM IRQ VECTOR
  074C  A205                LDX     #5
  074E  BDB40D      CLSVCT  LDA     RVSAVE,X
  0751  9D0A02              STA     VSERIN,X
