  0DBA  = 0002      RMAINV  DS      2       ;STORAGE FOR VIMIRQ, MAIN SYTEM IRQ VECTOR
  0DBC  = 0001      ALLDUN  DS      1       ;FLAG INDICATING INTERUPT-DRIVEN I/O IS COMPLETE
