  0BC9  8D0A03              STA     DAUX1
  0BCC  A940                LDA     #64
  0BCE  8D0803              STA     DBYTLO  ;KLUDGE TO COMPENSATE FOR AN O.S. BUG
  0BD1  60                  RTS
                    
                    
                    
                    ;       SUBROUTINE TO FIND THE PARITY OF THE ACCUMULATOR
                    ;
                    ;       GIVEN:  A=BYTE TO FIND PARITY OF
                    ;
                    ;       REGISTER USAGE:
                    ;               X=USED FOR COUNTING ONES
                    ;
                    ;       RESULT RETURNED IN CARRY
                    ;
  0BD2  A200        PARITY  LDX     #0
  0BD4  4A          CKPTLP  LSR     A
  0BD5  9001 ^0BD8          BCC     ZERBIT  ;IGNORE, ZERO-BIT
  0BD7  E8                  INX             ;COUNT A ONE BIT
  0BD8  D0FA ^0BD4  ZERBIT  BNE     CKPTLP  ;TEST FOR ALL DONE (BYTE=0)
  0BDA  8A                  TXA
  0BDB  4A                  LSR     A       ;SET CARRY DEPENDENT ON RESULT
  0BDC  60                  RTS
                    
                    
