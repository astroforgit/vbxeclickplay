     372  F024  D0 34                     BNE     ASY19           ;3 GO IF SO 
     373  F026  AD 80 01                  LDA     PORT1           ;4 LATCH OTHER 1/2 STATUS 
     374  F029  05 A0                     ORA     LOHIST          ;3 
     375  F02B  85 A0                     STA     LOHIST          ;3 
     376  F02D  A9 01                     LDA     #$01            ;2 TEST FOR START BIT 
