     338                          ;---------------------------------------------------------------- 
     339                          ;       19.2 KBAUD ASYNCH READ ROUTINE: 
     340                          ;               READS FROM SERIAL PORT 
     341                          ;               TWO ENTRIES--AST19C READS COMMANDS, RESETS IF COM RISES 
     342                          ;                       AST19 READS DATA, RESETS IF COM FALLS 
     343                          ;               ERROR RETURN (C SET) ON DATA READ ERROR, 
     344                          ;                  TIMEOUT, OR TOO MANY BYTES 
     345                          ;               TIMEOUT INITIALLY SET EXTERNALLY, PIA2 CLOCK AND 'TIMOUT
     346                          ;---------------------------------------------------------------- 
     347                          ; 
     348                          ; 
     349                          ; 
     350  F000                    AST19C  =       * 
     351  F000  8D 84 01                  STA     COMLO           ; SET UP DETECT COMMAND RISE 
     352  F003  4C 09 F0                  JMP     AST19S          ; GO FINISH SETUP 
     353  F006                    AST19   =       * 
     354  F006  8D 85 01                  STA     COMHI           ; SET UP DETECT COMMAND FALL 
     355                          ; 
     356  F009                    AST19S  = * 
     357  F009  AE 85 01                  LDX     INTS2           ; RESET INTERRUPT FLAG BITS 
     358  F00C  A6 AA                     LDX     BUFUSE          ; BUFFER SIZE INTO X 
     359  F00E  E8                        INX                     ; INCLUDE CHECKSUM BYTE 
     360                          ; 
     361  F00F                    AST19L  =       * 
