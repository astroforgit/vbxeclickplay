     363  F011  24 00                     BIT     PORTD           ;3 
     364  F013  F0 02                     BEQ     *+4             ;3 BRANCH IF NOT 
     365  F015  D0 43                     BNE     ASY19           ;3 GO IF SO 
     366  F017  AD 80 01                  LDA     PORT1           ;4 LATCH 1/2 STATUS 
     367  F01A  25 A1                     AND     HILOST          ;3 
     368  F01C  85 A1                     STA     HILOST          ;3 
     369  F01E  A9 01                     LDA     #$01            ;2 TEST FOR START BIT 
