     132                          ;               6       IN      BUSY    0=BUSY 
     133                          ;               5       OUT     STROBE  1=STROBE 
     134                          ;               4       OUT     RTS 1   - 
     135                          ;               3       OUT     DTR 3   - 
     136                          ;               2       OUT     DTR 2   - 
     137                          ;               1       OUT     DTR 1   - 
     138                          ;               0       IN      RCV 4   + 
     139                          ;       PORT1=MODEM IN PORT 
     140                          ;               7       IN      COMMAND 1=COMMAND 
     141                          ;               6       ---     ---     --- 
     142                          ;               5       IN      CTS 1   - 
     143                          ;               4       IN      CARRIER - 
     144                          ;               3       IN      DSR 3   - 
     145                          ;               2       IN      DSR 2   - 
     146                          ;               1       IN      DSR 1   - 
     147                          ;               0       IN      RCV 1   + 
     148                          ;       PORTP=PRINTER OUT PORT, ALL - LOGIC 
     149                          ; 
