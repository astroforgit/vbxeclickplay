     878                          ;               ON ENTRY, Y CONTAINS MASK TO SELECT PROPER 
     879                          ;                  BIT FROM PORT1.  ON EXIT, A CONTAINS SELECTED 
     880                          ;                  BIT FROM PORT1 AND NEXT LOWER BIT IS 1 IF 
     881                          ;                  PORT1 IS ONE AND HILOST AND LOHIST SHOW THAT 
     882                          ;                  BIT TO HAVE BEEN ALWAYS 1 SINCE LAST RSSENS, 
     883                          ;                  OR IF PORT1 IS ZERO AND HILOST AND LOHIST SHOW 
     884                          ;                  THAT IT WAS 1 SOMETIME SINCE LAST RSSENS; 
     885                          ;                  ELSE THE NEXT LOWER BIT IS ZERO. 
     886                          ;---------------------------------------------------------------- 
     887                          ; 
     888                          ; 
     889  F297                    RSSENS  = * 
     890  F297  AE 80 01                  LDX     PORT1           ; CURRENT VALUE OF PORT1 
     891  F29A  8A                        TXA 
     892  F29B  25 A1                     AND     HILOST          ; 1/2 LASTAT 
     893  F29D  85 A1                     STA     HILOST 
     894  F29F  8A                        TXA 
     895  F2A0  05 A0                     ORA     LOHIST          ; OTHER 1/2 
     896  F2A2  85 A0                     STA     LOHIST 
     897  F2A4  86 A5                     STX     RSTEMP          ; RSTEMP <- PORT1 
     898  F2A6  45 A1                     EOR     HILOST 
     899  F2A8  45 A5                     EOR     RSTEMP          ; A <- 'SINCE LAST STATUS' 
     900  F2AA  84 A5                     STY     RSTEMP          ; RSTEMP <- MASK 
     901  F2AC  25 A5                     AND     RSTEMP          ; MASK BIT IN A REG 
     902  F2AE  4A                        LSR     A               ; AND PUT IT IN ITS PLACE 
     903  F2AF  86 A5                     STX     RSTEMP          ; RSTEMP <- PORT1 
     904  F2B1  AA                        TAX                     ; X <- MASKED SHIFTED 'SINCE' BIT 
     905  F2B2  98                        TYA 
     906  F2B3  25 A5                     AND     RSTEMP          ; MASK PORT1 
     907  F2B5  86 A5                     STX     RSTEMP 
     908  F2B7  05 A5                     ORA     RSTEMP          ; PUT IT ALL TOGETHER 
     909  F2B9  60                        RTS ERR LINE  ADDR  B1 B2 B3 B4        RS-232 PERIPHERAL  STARTED 10/25/79  SCHEIMAN             PAGE   26

