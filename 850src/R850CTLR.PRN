     123                          ;               6       IN      FAULT   1=NO PRINTER 
     124                          ;               5       OUT     DATA-TO + 
     125                          ;               4       OUT     SEND 4  + 
     126                          ;               3       OUT     SEND 3  + 
     127                          ;               2       OUT     SEND 2  + 
     128                          ;               1       OUT     SEND 1  + 
     129                          ;               0       IN      DATA-FR - 
