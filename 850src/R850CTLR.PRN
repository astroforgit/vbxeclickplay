     911                          ;---------------------------------------------------------------- 
     912                          ;       TWO ROUTINES TO SET/CLEAR DTR,RTS, AND XMT 
     913                          ;               CALLED FROM RSCON (CONTROL) WITH A=MASK 
     914                          ;               OF WHAT BIT IN AUX1 TO CHECK, AND Y=MASK 
     915                          ;               OF WHAT BIT TO SET/CLEAR.  RSRDY SETS/CLEARS 
     916                          ;               BITS IN PORTR; RSXMT SETS/CLEARS PORTD 
     917                          ;---------------------------------------------------------------- 
     918                          ; 
     919  F2BA                    RSRDY   = * 
     920  F2BA  24 AE                     BIT     BUFE-1+2                ; AUX1 
     921  F2BC  F0 11                     BEQ     RSREX           ; GO RETURN IF NO ACTION OK'D 
     922  F2BE  4A                        LSR     A               ; LINE UP MASK 
     923  F2BF  24 AE                     BIT     BUFE-1+2 
     924  F2C1  D0 05                     BNE     RSRDYS          ; BRANCH=GO SET; ELSE CLEAR 
     925  F2C3  98                        TYA 
     926  F2C4  05 02                     ORA     PORTR 
     927  F2C6  D0 05                     BNE     RSRDYD          ; GO FINISH 
     928  F2C8                    RSRDYS  = * 
     929  F2C8  98                        TYA 
     930  F2C9  49 FF                     EOR     #$FF            ; FLIP MASK 
     931  F2CB  25 02                     AND     PORTR 
     932  F2CD                    RSRDYD  = * 
     933  F2CD  85 02                     STA     PORTR           ; STORE NEW VALUE WITH SET/CLEAR BIT 
     934  F2CF                    RSREX   = * 
     935  F2CF  60                        RTS 
     936                          ; 
     937                          ; 
     938  F2D0                    RSXMT   = * 
     939  F2D0  A9 02                     LDA     #$02            ; IN MASK (NOT PASSED FROM CALLER) 
     940  F2D2  24 AE                     BIT     BUFE-1+2        ; AUX1 
     941  F2D4  F0 F9                     BEQ     RSREX           ; GO RETURN IF NO ACTION ALLOWED 
     942  F2D6  4A                        LSR     A               ; SHIFT MASK 
     943  F2D7  24 AE                     BIT     BUFE-1+2 
     944  F2D9  F0 05                     BEQ     RSXMTC          ; BRANCH=CLEAR BIT; ELSE SET 
     945  F2DB  98                        TYA 
     946  F2DC  05 00                     ORA     PORTD           ; SET BIT 
     947  F2DE  D0 05                     BNE     RSXMTD          ; GO FINISH 
     948  F2E0                    RSXMTC  = * 
     949  F2E0  98                        TYA 
     950  F2E1  49 FF                     EOR     #$FF            ; FLIP MASK 
     951  F2E3  25 00                     AND     PORTD           ; CLEAR BIT 
     952  F2E5                    RSXMTD  = * 
     953  F2E5  85 00                     STA     PORTD           ; STORE WITH SET/CLEAR BIT 
     954  F2E7  60                        RTS ERR LINE  ADDR  B1 B2 B3 B4        RS-232 PERIPHERAL  STARTED 10/25/79  SCHEIMAN             PAGE   27

