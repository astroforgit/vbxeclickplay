     957                          ;       ROUTINE TO SEND BUFFER TO COMPUTER <<INCLUDING CHECKSUM>> 
     958                          ;               PERFORMS ERROR RESET IF COMMAND LINE FALLS 
     959                          ;---------------------------------------------------------------- 
     960                          ; 
     961  F2E8                    TOCOMP  = * 
