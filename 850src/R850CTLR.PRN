      34                          ;       QUICK SUMMARY OF I/O: 
      35                          ; 
      36                          ; 
      37                          ;       PRINTER: 
      38                          ;               STATUS  (AUX BYTES CONTAIN NOTHING) 
      39                          ;                       RETURNS FLAGS (10000XYZ) 
      40                          ;                                       (X=BUSY,Y=DATA ERR,Z=CMD ERR) 
      41                          ;                               MOST PREVIOUS AUX1 
      42                          ;                               TIMEOUT IN SECONDS (TWO BYTES) 
      43                          ;               WRITE   (AUX1 CONTAINS 'N' FOR NORMAL) 
      44                          ;                               (COMPUTER SENDS 40 BYTES; 
      45                          ;                                DATA FOLLOWING AN EOL IS IGNORED) 
      46                          ; 
      47                          ; 
      48                          ;       RS232 PORTS: 
      49                          ; 
      50                          ;               STATUS (AUX CONTAINS NOTHING) 
      51                          ;                       RETURNS ERRORS (F000BNDC) 
      52                          ;                                       N=NOT READY ERROR (DSR,CTS,CRX) 
      53                          ;                                       F=FRAME ERROR 
      54                          ;                                       D=SERIAL DATA ERROR 
      55                          ;                                       B=ILLEGAL OPTION COMBINATION ON 
      56                          ;                                       C=ILLEGAL COMMAND ERROR 
      57                          ;                               SENSE (RSCDXY0Z) 
      58                          ;                                       R=DSR 
      59                          ;                                       S=DSR SINCE PREV STATUS 
      60                          ;                                       C=CTS 
      61                          ;                                       D=CTS SINCE PREV STATUS 
      62                          ;                                       X=CRX (CARRIER) 
      63                          ;                                       Y=CRX SINCE PREV STATUS 
      64                          ;                                       Z=RCV (DATA NOW) 
      65                          ; 
      66                          ;               WRITE (AUX1=LLLLLLLL) 
      67                          ;                       LLLLLLLL=TRANSMISSION LENGTH (MAY BE 0) 
      68                          ;                               WILL RECEIVE 64 BYTES, THEN WRITE LLLLLL
      69                          ; 
      70                          ;               BAUD (AUX1=T*NNBBBB,AUX2=*****RCX) 
      71                          ;                       T=2 STOP BITS 
      72                          ;                       NN=WORD SIZE (00=8,11=5,10=6,01=7) 
      73                          ;                       BBBB=BAUD SELECT 
      74                          ;                       R=WATCH READY LINE 
      75                          ;                       C=WATCH CLEAR TO SEND 
      76                          ;                       X=WATCH CARRIER 
      77                          ; 
      78                          ;               CONTROL (AUX1=RSCD**AB) 
      79                          ;                       R=ENABLE SETTING DTR 
      80                          ;                       S=DTR 
      81                          ;                       C=ENBALE SETTING RTS 
      82                          ;                       D=RTS 
      83                          ;                       A=ENABLE SETTING XMT 
      84                          ;                       B=XMT 
      85                          ; 
      86                          ;               STREAM (AUX1=****WR**) ERR LINE  ADDR  B1 B2 B3 B4        RS-232 PERIPHERAL  STARTED 10/25/79  SCHEIMAN             PAGE    4

      87                          ;                       W=OUT, R=IN 
      88                          ; 
      89                          ;       MISC I/O: 
      90                          ; 
      91                          ;               TEST (RS232 PORT 1 ADDRESS; AUX1=LLLLLLLL) 
      92                          ;                       LLLLLLLL=BYTE COUNT 
      93                          ;                               WILL RECEIVE LLLLLLLL BYTES THEN JUMP TO
      94                          ;                               IN BUFFER AS TEST CODE 
      95                          ; 
      96                          ;               DISK STATUS REQUEST (AUX NOTHING) 
      97                          ;                       RETURNS FLAGS,0,TIMEOUT (2 BYTES?????) 
      98                          ;                       FLAGS=00001000 (WRITE PROTECTED) 
      99                          ; 
     100                          ;               DISK READ (AUX1,AUX2=SECTOR LSB,MSB) 
     101                          ;                       RETURNS 128 DATA BYTES 
     102                          ; 
     103                          ;       NOTES ON PSEUDO-DISK BOOT:  BOOT STARTS WITH READ FROM SECTOR 1 
     104                          ;               DATA:  FLAGS 
     105                          ;               NUMBER OF SECTORS (INCLUDING FIRST) 
     106                          ;               LOAD ADDRESS (TWO BYTES) 
     107                          ;               DOSINI ADDRESS (TWO BYTES) 
     108                          ;               DATA 
     109                          ; 
     110                          ;               THE BOOT WILL LOAD INFO 
     111                          ;               STARTING AT THE LOAD ADDRESS. 
     112                          ;               SUBSEQUENT SECTORS WILL BE READ IN ASCENDING ORDER FROM 
     113                          ;               AFTER THE READS ARE DONE, THE OS WILL JSR TO THE 
     114                          ;               LOAD ADDRESS+6.  THE ROUTINE SHOULD RTS WITH CARRY 
     115                          ;               CLEAR TO INDICATE NO ERROR.  THE OS THEN JSR'S TO 
     116                          ;               THE DOSINI ROUTINE.  THIS LATTER ENTRY IS CALLED ON 
     117                          ;               ANY SUBSEQUENT WARM STARTS. ERR LINE  ADDR  B1 B2 B3 B4        RS-232 PERIPHERAL  STARTED 10/25/79  SCHEIMAN             PAGE    5

