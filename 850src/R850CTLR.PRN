     966  F2EE  20 8A F0                  JSR     TOCOMB          ; SEND IT 
     967  F2F1  B0 04                     BCS     TOCMPR          ; IF COMMAND ERROR RETURNED, ERROR RESET
     968  F2F3  CA                        DEX                     ; BUMP POINTER 
     969  F2F4  D0 F5                     BNE     TOCMPL          ; LOOP IF MORE IN BUFFER 
     970  F2F6  60                        RTS                     ; RETURN WHEN DONE 
     971                          ; 
     972  F2F7                    TOCMPR  = * 
     973  F2F7  4C BA F8                  JMP     MAIN            ; ERROR--RESET 
