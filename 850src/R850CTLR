        LDX     #$01            ; ELSE SET COMMAND ERROR
        STX     PORT1S,Y
        JMP     COMNAK          ; GO SEND NAK TO COMPUTER
;
RSDOW   = *
        LDY     #4+4            ; POINTER INTO BTOP TABLE FOR BTOCOM
        JMP     BTOCOM
