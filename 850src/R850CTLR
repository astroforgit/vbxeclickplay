;       START VECTOR, HARDWARE VECTORS
;----------------------------------------------------------------
;
;
CHKSUM  =       $86D3           ;$686D3
VERSON  =       1               ; REVISION NUMBER
;
        *=      $FFF8
HNDCHK  .BYTE   $C5                     ; HANDLER CHECKSUM
        .BYTE   VERSON
        .WORD   CHKSUM,RESET,LSTAT
;
        .END
