HANDLE  =       $FFF9           ; END OF HANDLER (INCL CHECK) PLUS 1
HANDLL  =       $591            ; HANDLER BODY SIZE
HANDLB  =       HANDLE-HANDLL-1 ; BEGINNING OF HANDLER IN THIS ROM
BOOTE   =       HANDLB          ; END OF BOOTER/RELOCATOR (INCL CHECK) PLUS 1
BOOTL   =       $14F            ; LENGTH OF BOOTER/RELOCATOR
